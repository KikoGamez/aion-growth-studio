---
import '../../styles/global.css';

const blogPosts = [
  {
    slug: 'futuro-ia-marketing',
    titleEs: 'El Futuro de la IA en Marketing Growth',
    descriptionEs: 'Descubre cómo la inteligencia artificial está revolucionando la forma en que las marcas crecen y escalan sus operaciones.',
    author: 'Alex Rivera',
    date: '2024-03-15',
    category: 'IA',
    image: 'https://images.unsplash.com/photo-1677442d019cecf8f6a3c44eae308d8dcc1b330b?w=800&h=400&fit=crop',
  },
  {
    slug: 'growth-sovereignty',
    titleEs: 'Growth Sovereignty: La Nueva Frontera del Control de Datos',
    descriptionEs: 'Por qué el control total de tus datos de marketing es el factor diferenciador más importante en 2024.',
    author: 'Sofia Chen',
    date: '2024-03-10',
    category: 'Strategy',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=400&fit=crop',
  },
  {
    slug: 'neural-media-buying',
    titleEs: 'Neural Media Buying: La Revolución de la Compra Programática',
    descriptionEs: 'Cómo los algoritmos neuronales están transformando la compra de media digital y reduciendo costos.',
    author: 'Marcus Torres',
    date: '2024-03-05',
    category: 'Technology',
    image: 'https://images.unsplash.com/photo-1573607891914-a68fb5baaf45?w=800&h=400&fit=crop',
  },
  {
    slug: 'sentiment-mapping',
    titleEs: 'Predictive Sentiment Mapping: Lee la Mente del Mercado',
    descriptionEs: 'Técnicas avanzadas para predecir el sentimiento del mercado antes de que ocurra.',
    author: 'Elena Vasquez',
    date: '2024-02-28',
    category: 'Analytics',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&h=400&fit=crop',
  },
];
---

<!doctype html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="description" content="Blog — AION Growth Studio" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>Blog | AION Growth Studio</title>
</head>
<body class="font-sans antialiased bg-background text-on-surface">

  <!-- NAVBAR -->
  <nav class="fixed top-0 w-full z-50 bg-primary">
    <div class="relative flex justify-between items-center px-8 py-3 max-w-7xl mx-auto">
      <a href="/es/" class="flex items-center gap-2 h-12 overflow-hidden">
        <img src="/images/aion-logo-dark.png" alt="AION Growth Studio" class="h-24 w-auto" />
      </a>
      <div class="hidden lg:flex items-center gap-8">
        <a href="/es/#solutions" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">Soluciones</a>
        <a href="/blog" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">Blog</a>
        <a href="/contacto" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">Contacto</a>
      </div>
      <div class="flex items-center gap-2">
        <a href="/login" class="hidden md:flex items-center gap-1.5 text-xs font-semibold text-white/80 hover:text-white px-3 py-2 rounded-full bg-white/10 transition-all hover:bg-white/20">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Iniciar Sesión</span>
        </a>
        <a href="/es/diagnostico" class="hidden md:block bg-accent text-primary px-5 py-2.5 rounded-full font-bold text-xs hover:brightness-110 transition-all" style="box-shadow: 0 4px 20px rgba(105,255,135,0.35);">
          Diagnóstico Gratuito
        </a>
      </div>
    </div>
  </nav>

  <main class="min-h-screen pt-20">
    <section class="py-20 px-8 max-w-7xl mx-auto">
      <h1 class="text-5xl font-bold text-foreground mb-12 text-balance">Blog de IA y Growth</h1>

      <div class="grid md:grid-cols-2 gap-8">
        {blogPosts.map((post) => (
          <a href={`/blog/${post.slug}`}>
            <div class="group cursor-pointer rounded-xl overflow-hidden border border-border hover:border-accent/50 transition-all duration-300 bg-surface-container h-full flex flex-col">
              <div class="relative h-48 overflow-hidden bg-background">
                <img src={post.image} alt={post.titleEs} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <div class="flex gap-2 mb-3">
                  <span class="inline-block px-3 py-1 bg-accent/20 text-accent text-xs font-semibold rounded-full">{post.category}</span>
                </div>
                <h2 class="text-xl font-bold text-foreground mb-3 group-hover:text-accent transition-colors line-clamp-2">{post.titleEs}</h2>
                <p class="text-foreground/70 text-sm mb-4 flex-grow line-clamp-3">{post.descriptionEs}</p>
                <div class="flex items-center justify-between pt-4 border-t border-border/30">
                  <div>
                    <p class="text-xs text-foreground/60">{post.author}</p>
                    <p class="text-xs text-foreground/50">{post.date}</p>
                  </div>
                  <span class="text-accent font-semibold text-sm">→</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <!-- FOOTER -->
  <footer class="w-full py-12 bg-surface-container-low">
    <div class="flex flex-col md:flex-row justify-between items-center px-8 max-w-7xl mx-auto gap-6">
      <div class="flex flex-col items-center md:items-start">
        <a href="/es/" class="flex items-center"><img src="/images/aion-logo-full.png" alt="AION Growth Studio" class="h-24 w-auto" /></a>
        <span class="text-xs text-on-surface-variant mt-2">Infraestructura de crecimiento con IA agentiva</span>
      </div>
      <div class="flex flex-wrap justify-center gap-6 md:gap-8">
        <a href="#" class="font-sans text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors">Privacidad</a>
        <a href="#" class="font-sans text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors">Términos</a>
        <a href="#" class="font-sans text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors">LinkedIn</a>
        <a href="/contacto" class="font-sans text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors">Contacto</a>
      </div>
      <div class="text-xs text-on-surface-variant">© 2024 AION Growth Studio. Todos los derechos reservados.</div>
    </div>
  </footer>
</body>
</html>
