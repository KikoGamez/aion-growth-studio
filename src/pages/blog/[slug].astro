---
export const prerender = false;

import '../../styles/global.css';
import { fetchPostBySlug, fetchPostContent } from '../../lib/notion';

const { slug } = Astro.params;
const post = await fetchPostBySlug(slug!);

if (!post) {
  return Astro.redirect('/blog');
}

const content = await fetchPostContent(post.id);
const dateLocale = 'es-ES';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="description" content={post.description} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>{post.title} | AION Growth Studio</title>
</head>
<body class="font-sans antialiased bg-background text-on-surface">

  <!-- NAVBAR -->
  <nav class="fixed top-0 w-full z-50 bg-primary">
    <div class="relative flex justify-between items-center px-8 py-3 max-w-7xl mx-auto">
      <a href="/es/" class="flex items-center gap-2 h-12 overflow-hidden">
        <img src="/images/aion-logo-dark.png" alt="AION Growth Studio" class="h-24 w-auto" />
      </a>
      <div class="hidden lg:flex items-center gap-8">
        <a href="/es/#solutions" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">Soluciones</a>
        <a href="/blog" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">Blog</a>
        <a href="/contacto" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">Contacto</a>
      </div>
      <div class="flex items-center gap-2">
        <a href="/login" class="hidden md:flex items-center gap-1.5 text-xs font-semibold text-white/80 hover:text-white px-3 py-2 rounded-full bg-white/10 transition-all hover:bg-white/20">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Iniciar Sesión</span>
        </a>
        <a href="/es/diagnostico" class="hidden md:block bg-accent text-primary px-5 py-2.5 rounded-full font-bold text-xs hover:brightness-110 transition-all" style="box-shadow: 0 4px 20px rgba(105,255,135,0.35);">
          Diagnóstico Gratuito
        </a>
      </div>
    </div>
  </nav>

  <main class="min-h-screen pt-20">
    <!-- Hero header -->
    <div class="bg-primary relative overflow-hidden py-16">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 32px 32px;"></div>
      <div class="relative max-w-3xl mx-auto px-8">
        <a href="/blog" class="inline-flex items-center gap-2 text-white/50 hover:text-white text-sm mb-8 transition-colors group">
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Volver al blog
        </a>

        {post.category && (
          <span class="inline-block px-3 py-1 bg-accent/20 text-accent text-xs font-semibold rounded-full mb-6 tracking-wide uppercase">
            {post.category}
          </span>
        )}

        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-8 leading-tight tracking-tight">
          {post.title}
        </h1>

        <div class="flex flex-wrap items-center gap-4 text-sm">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
              <span class="text-white text-sm font-bold">{post.author?.charAt(0) || 'A'}</span>
            </div>
            <div>
              <p class="text-white font-medium">{post.author}</p>
              <p class="text-white/50 text-xs">
                <time datetime={post.date}>
                  {post.date ? new Date(post.date).toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' }) : ''}
                </time>
                {post.readTime && <span> &middot; {post.readTime}</span>}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Featured image -->
    {post.image && (
      <div class="max-w-3xl mx-auto px-8 -mt-8 relative z-10">
        <img src={post.image} alt={post.title} class="w-full rounded-2xl shadow-2xl" />
      </div>
    )}

    <!-- Content -->
    <article class="max-w-3xl mx-auto px-8 py-12 md:py-20">
      <div class="prose max-w-none">
        <Fragment set:html={content} />
      </div>

      <div class="border-t border-border pt-8 mt-12">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:opacity-80 transition-opacity group">
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Volver al blog
        </a>
      </div>
    </article>
  </main>

  <!-- FOOTER -->
  <footer class="w-full py-12 bg-surface-container-low">
    <div class="flex flex-col md:flex-row justify-between items-center px-8 max-w-7xl mx-auto gap-6">
      <div class="flex flex-col items-center md:items-start">
        <a href="/es/" class="flex items-center"><img src="/images/aion-logo-full.png" alt="AION Growth Studio" class="h-24 w-auto" /></a>
        <span class="text-xs text-on-surface-variant mt-2">Infraestructura de crecimiento con IA agentiva</span>
      </div>
      <div class="text-xs text-on-surface-variant">© 2024 AION Growth Studio. Todos los derechos reservados.</div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  .prose { color: #43474d; }
  .prose h2 { font-size: 1.875rem; font-weight: 700; color: #001d32; margin-top: 3rem; margin-bottom: 1.5rem; }
  .prose h3 { font-size: 1.5rem; font-weight: 600; color: #001d32; margin-top: 2rem; margin-bottom: 1rem; }
  .prose p { font-size: 1.125rem; line-height: 1.75; margin-bottom: 1.5rem; }
  .prose a { color: #000e41; font-weight: 500; text-decoration: underline; text-decoration-color: rgba(0,14,65,0.3); text-underline-offset: 2px; transition: text-decoration-color 0.2s; }
  .prose a:hover { color: #001f70; text-decoration-color: #001f70; }
  .prose strong { color: #001d32; font-weight: 600; }
  .prose ul, .prose ol { margin: 1.5rem 0; padding-left: 1.5rem; }
  .prose li { font-size: 1.125rem; margin-bottom: 0.5rem; }
  .prose li::marker { color: #000e41; }
  .prose blockquote { border-left: 3px solid #000e41; padding: 1.5rem; font-style: italic; margin: 2rem 0; color: #43474d; background: rgba(0,14,65,0.03); border-radius: 0 0.75rem 0.75rem 0; }
  .prose code { background: #edf4ff; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875rem; color: #000e41; }
  .prose pre { background: #000e41; color: #e3efff; border-radius: 0.75rem; padding: 1.5rem; overflow-x: auto; margin: 2rem 0; }
  .prose pre code { background: transparent; color: inherit; padding: 0; }
  .prose img { border-radius: 0.75rem; margin: 2rem 0; }
  .prose > p:first-child > img:only-child { display: none; }
  .prose hr { border-color: #c3c6ce; margin: 3rem 0; }
</style>
