---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { IS_DEMO, getSupabase } from '../../../lib/db';

const user = (Astro.locals as any).user;
if (!user || user.role !== 'superuser') return Astro.redirect('/dashboard');

// Query params for filters
const status = Astro.url.searchParams.get('status') || '';
const search = Astro.url.searchParams.get('q') || '';
const source = Astro.url.searchParams.get('source') || '';
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const perPage = 50;

let leads: any[] = [];
let totalCount = 0;
let sources: string[] = [];

if (!IS_DEMO) {
  const sb = getSupabase();

  // Get unique sources for filter dropdown
  const { data: srcData } = await sb.from('leads').select('utm_source').not('utm_source', 'is', null);
  sources = [...new Set((srcData || []).map((r: any) => r.utm_source).filter(Boolean))].sort();

  // Build filtered query
  let query = sb.from('leads').select('*', { count: 'exact' });
  if (status) query = query.eq('status', status);
  if (source) query = query.eq('utm_source', source);
  if (search) query = query.or(`email.ilike.%${search}%,url.ilike.%${search}%`);
  query = query.order('created_at', { ascending: false }).range((page - 1) * perPage, page * perPage - 1);

  const { data, count } = await query;
  leads = data || [];
  totalCount = count || 0;
}

const totalPages = Math.ceil(totalCount / perPage);
const statuses = ['', 'new', 'audit_started', 'audit_completed', 'registered', 'paying', 'churned'];
const statusLabels: any = { '': 'Todos', new: 'Nuevo', audit_started: 'Audit empezado', audit_completed: 'Audit completo', registered: 'Registrado', paying: 'Pagando', churned: 'Churn' };
---

<AdminLayout title="CRM — Leads" currentPath="/admin/crm/leads">
  <!-- Filters -->
  <div class="filter-bar">
    <form method="get" style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;width:100%;">
      <input type="text" name="q" placeholder="Buscar email o URL..." value={search} style="flex:1;min-width:200px;" />
      <select name="status">
        {statuses.map((s) => (
          <option value={s} selected={s === status}>{statusLabels[s]}</option>
        ))}
      </select>
      {sources.length > 0 && (
        <select name="source">
          <option value="">Todas las fuentes</option>
          {sources.map((s) => (
            <option value={s} selected={s === source}>{s}</option>
          ))}
        </select>
      )}
      <button type="submit" class="btn btn-primary">
        <span class="material-symbols-outlined" style="font-size:16px;">filter_list</span>
        Filtrar
      </button>
      {(status || search || source) && (
        <a href="/admin/crm/leads" class="btn btn-ghost">Limpiar</a>
      )}
    </form>
  </div>

  <!-- Stats row -->
  <div style="display:flex;gap:12px;margin-bottom:20px;font-size:12px;color:#64748b;">
    <span>{totalCount} leads encontrados</span>
    {totalPages > 1 && <span>Pagina {page} de {totalPages}</span>}
  </div>

  <!-- Table -->
  <div class="stat-card" style="padding:0;overflow-x:auto;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Email</th>
          <th>URL auditada</th>
          <th>Estado</th>
          <th>Fuente</th>
          <th>Campana</th>
          <th>Fecha</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {leads.length === 0 ? (
          <tr><td colspan="7" style="text-align:center;padding:32px;color:#94a3b8;">No se han encontrado leads</td></tr>
        ) : leads.map((lead: any) => (
          <tr>
            <td style="font-weight:600;">{lead.email || <span style="color:#94a3b8;">sin email</span>}</td>
            <td>
              <a href={lead.url} target="_blank" style="color:#6366f1;text-decoration:none;font-size:12px;">
                {(lead.url || '').replace(/^https?:\/\//,'').slice(0,35)}
              </a>
            </td>
            <td><span class={`badge ${lead.status}`}>{lead.status}</span></td>
            <td style="font-size:12px;color:#64748b;">{lead.utm_source || lead.source || '—'}</td>
            <td style="font-size:12px;color:#64748b;">{lead.utm_campaign || '—'}</td>
            <td style="font-size:12px;color:#64748b;white-space:nowrap;">
              {lead.created_at ? new Date(lead.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' }) : '—'}
            </td>
            <td>
              {lead.audit_id && (
                <a href={`/admin/audit/${lead.audit_id}`} class="btn btn-ghost" style="font-size:11px;padding:4px 10px;">
                  <span class="material-symbols-outlined" style="font-size:14px;">bug_report</span>
                </a>
              )}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  {totalPages > 1 && (
    <div style="display:flex;justify-content:center;gap:8px;margin-top:20px;">
      {page > 1 && (
        <a href={`/admin/crm/leads?page=${page - 1}${status ? '&status=' + status : ''}${search ? '&q=' + search : ''}${source ? '&source=' + source : ''}`} class="btn btn-ghost">Anterior</a>
      )}
      {page < totalPages && (
        <a href={`/admin/crm/leads?page=${page + 1}${status ? '&status=' + status : ''}${search ? '&q=' + search : ''}${source ? '&source=' + source : ''}`} class="btn btn-ghost">Siguiente</a>
      )}
    </div>
  )}
</AdminLayout>
