---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listAllClients, getLeadStats, IS_DEMO, getSupabase } from '../../lib/db';

const user = (Astro.locals as any).user;
if (!user || user.role !== 'superuser') return Astro.redirect('/dashboard');

const clients = await listAllClients();
const leadStats = IS_DEMO ? null : await getLeadStats();

// Correct field mapping from getLeadStats()
const byStatus = leadStats?.byStatus ?? {};
const totalLeads = leadStats?.total ?? 0;
const leads30d = leadStats?.last30Days ?? 0;
const completedAudits = (byStatus.audit_completed ?? 0) + (byStatus.registered ?? 0) + (byStatus.paying ?? 0) + (byStatus.churned ?? 0);
const registeredUsers = (byStatus.registered ?? 0) + (byStatus.paying ?? 0) + (byStatus.churned ?? 0);
const payingClients = byStatus.paying ?? 0;
const churnedClients = byStatus.churned ?? 0;
const recentLeads = leadStats?.recentLeads?.slice(0, 8) ?? [];

// Conversion rates (cumulative: each stage includes subsequent stages)
const leadToAudit = totalLeads > 0 ? Math.round((completedAudits / totalLeads) * 100) : 0;
const auditToRegister = completedAudits > 0 ? Math.round((registeredUsers / completedAudits) * 100) : 0;
const registerToPay = registeredUsers > 0 ? Math.round((payingClients / registeredUsers) * 100) : 0;
const churnRate = (payingClients + churnedClients) > 0 ? Math.round((churnedClients / (payingClients + churnedClients)) * 100) : 0;

// Funnel
const funnelSteps = [
  { label: 'Leads captados', count: totalLeads, icon: 'person_search', color: '#64748b' },
  { label: 'Audit completado', count: completedAudits, icon: 'fact_check', color: '#3b82f6' },
  { label: 'Registrados', count: registeredUsers, icon: 'how_to_reg', color: '#8b5cf6' },
  { label: 'Suscripcion activa', count: payingClients, icon: 'paid', color: '#10b981' },
];
const maxFunnel = Math.max(...funnelSteps.map(f => f.count), 1);

// Top sources
const bySource = leadStats?.bySource ?? {};
const topSources = Object.entries(bySource)
  .sort(([, a], [, b]) => (b as number) - (a as number))
  .slice(0, 5);
const maxSource = topSources.length > 0 ? (topSources[0][1] as number) : 1;

// Audit stats (last 7 days)
let auditsLast7d = 0;
let avgScore = 0;
if (!IS_DEMO) {
  try {
    const sb = getSupabase();
    const since = new Date(Date.now() - 7 * 86_400_000).toISOString();
    const { count } = await sb.from('audits').select('id', { count: 'exact', head: true }).gte('created_at', since);
    auditsLast7d = count || 0;
    const { data: scoreData } = await sb.from('audits').select('score').gte('created_at', since).not('score', 'is', null);
    if (scoreData && scoreData.length > 0) {
      avgScore = Math.round(scoreData.reduce((s: number, r: any) => s + (r.score || 0), 0) / scoreData.length);
    }
  } catch {}
}
---

<AdminLayout title="Metricas" currentPath="/admin">

  <!-- ══ KPI Hero Cards ══ -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;margin-bottom:32px;">
    <div class="stat-card" style="border-top:3px solid #6366f1;">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
          <div class="label">Leads totales</div>
          <div class="value">{totalLeads}</div>
        </div>
        <div style="width:44px;height:44px;border-radius:12px;background:#eef2ff;display:flex;align-items:center;justify-content:center;">
          <span class="material-symbols-outlined" style="font-size:22px;color:#6366f1;">group</span>
        </div>
      </div>
      <div class="delta" style="margin-top:8px;">+{leads30d} ultimos 30 dias</div>
    </div>

    <div class="stat-card" style="border-top:3px solid #3b82f6;">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
          <div class="label">Auditorias (7d)</div>
          <div class="value">{auditsLast7d}</div>
        </div>
        <div style="width:44px;height:44px;border-radius:12px;background:#eff6ff;display:flex;align-items:center;justify-content:center;">
          <span class="material-symbols-outlined" style="font-size:22px;color:#3b82f6;">lab_profile</span>
        </div>
      </div>
      <div class="delta" style="margin-top:8px;">Score medio: {avgScore || '—'}/100</div>
    </div>

    <div class="stat-card" style="border-top:3px solid #10b981;">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
          <div class="label">Clientes pagando</div>
          <div class="value" style="color:#10b981;">{payingClients}</div>
        </div>
        <div style="width:44px;height:44px;border-radius:12px;background:#ecfdf5;display:flex;align-items:center;justify-content:center;">
          <span class="material-symbols-outlined" style="font-size:22px;color:#10b981;">paid</span>
        </div>
      </div>
      <div class="delta" style="margin-top:8px;">{clients.length} clientes totales</div>
    </div>

    <div class="stat-card" style="border-top:3px solid #ef4444;">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
          <div class="label">Churn</div>
          <div class="value" style="color:#ef4444;">{churnedClients}</div>
        </div>
        <div style="width:44px;height:44px;border-radius:12px;background:#fef2f2;display:flex;align-items:center;justify-content:center;">
          <span class="material-symbols-outlined" style="font-size:22px;color:#ef4444;">person_off</span>
        </div>
      </div>
      <div class="delta down" style="margin-top:8px;">{churnRate}% churn rate</div>
    </div>
  </div>

  <!-- ══ Funnel + Conversion Rates ══ -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px;">

    <!-- Funnel visual -->
    <div class="stat-card">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;">
        <span class="material-symbols-outlined" style="font-size:20px;color:#6366f1;">filter_alt</span>
        <span style="font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;color:#64748b;">Funnel de conversion</span>
      </div>
      <div style="display:flex;flex-direction:column;gap:16px;">
        {funnelSteps.map((step, idx) => {
          const pct = maxFunnel > 0 ? Math.max(4, (step.count / maxFunnel) * 100) : 4;
          const dropPct = idx > 0 && funnelSteps[idx - 1].count > 0
            ? Math.round(((funnelSteps[idx - 1].count - step.count) / funnelSteps[idx - 1].count) * 100)
            : null;
          return (
            <div>
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                <div style="display:flex;align-items:center;gap:8px;">
                  <span class="material-symbols-outlined" style={`font-size:18px;color:${step.color};`}>{step.icon}</span>
                  <span style="font-size:13px;font-weight:600;color:#334155;">{step.label}</span>
                </div>
                <div style="display:flex;align-items:center;gap:8px;">
                  <span style="font-size:15px;font-weight:900;color:#1a1a2e;">{step.count}</span>
                  {dropPct != null && dropPct > 0 && (
                    <span style="font-size:10px;font-weight:600;color:#ef4444;background:#fef2f2;padding:2px 6px;border-radius:4px;">-{dropPct}%</span>
                  )}
                </div>
              </div>
              <div style="height:10px;background:#f1f5f9;border-radius:5px;overflow:hidden;">
                <div style={`width:${pct}%;height:100%;background:${step.color};border-radius:5px;transition:width 0.5s;`}></div>
              </div>
            </div>
          );
        })}
      </div>
      {churnedClients > 0 && (
        <div style="margin-top:16px;padding-top:14px;border-top:1px solid #f1f5f9;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div style="display:flex;align-items:center;gap:8px;">
              <span class="material-symbols-outlined" style="font-size:18px;color:#ef4444;">person_off</span>
              <span style="font-size:13px;font-weight:600;color:#ef4444;">Churn</span>
            </div>
            <span style="font-size:15px;font-weight:900;color:#ef4444;">{churnedClients}</span>
          </div>
        </div>
      )}
    </div>

    <!-- Conversion rates -->
    <div class="stat-card">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;">
        <span class="material-symbols-outlined" style="font-size:20px;color:#10b981;">trending_up</span>
        <span style="font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;color:#64748b;">Tasas de conversion</span>
      </div>
      <div style="display:flex;flex-direction:column;gap:20px;">
        {[
          { label: 'Lead → Audit completado', value: leadToAudit, from: totalLeads, to: completedAudits, color: '#3b82f6' },
          { label: 'Audit → Registro', value: auditToRegister, from: completedAudits, to: registeredUsers, color: '#8b5cf6' },
          { label: 'Registro → Pago', value: registerToPay, from: registeredUsers, to: payingClients, color: '#10b981' },
        ].map((rate) => (
          <div>
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
              <span style="font-size:13px;font-weight:600;color:#334155;">{rate.label}</span>
              <span style={`font-size:24px;font-weight:900;color:${rate.value > 0 ? rate.color : '#94a3b8'};`}>{rate.value}%</span>
            </div>
            <div style="height:6px;background:#f1f5f9;border-radius:3px;overflow:hidden;margin-bottom:4px;">
              <div style={`width:${Math.max(2, rate.value)}%;height:100%;background:${rate.color};border-radius:3px;`}></div>
            </div>
            <div style="font-size:11px;color:#94a3b8;">{rate.from} → {rate.to}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ══ Sources + Recent activity ══ -->
  <div style="display:grid;grid-template-columns:1fr 2fr;gap:20px;margin-bottom:32px;">

    <!-- Top sources -->
    <div class="stat-card">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;">
        <span class="material-symbols-outlined" style="font-size:20px;color:#f59e0b;">link</span>
        <span style="font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;color:#64748b;">Fuentes de leads</span>
      </div>
      {topSources.length > 0 ? (
        <div style="display:flex;flex-direction:column;gap:12px;">
          {topSources.map(([source, count]) => (
            <div>
              <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
                <span style="font-size:13px;font-weight:600;color:#334155;">{source}</span>
                <span style="font-size:13px;font-weight:800;color:#1a1a2e;">{count as number}</span>
              </div>
              <div style="height:6px;background:#f1f5f9;border-radius:3px;overflow:hidden;">
                <div style={`width:${((count as number) / maxSource) * 100}%;height:100%;background:#f59e0b;border-radius:3px;`}></div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div style="text-align:center;padding:24px;color:#94a3b8;font-size:13px;">Sin datos de fuentes</div>
      )}
    </div>

    <!-- Recent activity -->
    <div class="stat-card" style="padding:0;">
      <div style="padding:20px 24px 14px;display:flex;justify-content:space-between;align-items:center;">
        <div style="display:flex;align-items:center;gap:8px;">
          <span class="material-symbols-outlined" style="font-size:20px;color:#6366f1;">history</span>
          <span style="font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;color:#64748b;">Actividad reciente</span>
        </div>
        <a href="/admin/crm/leads" class="btn btn-ghost" style="font-size:11px;padding:4px 12px;">
          Ver todos <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>
        </a>
      </div>
      {recentLeads.length > 0 ? (
        <table class="admin-table">
          <thead>
            <tr>
              <th>Email</th>
              <th>URL</th>
              <th>Estado</th>
              <th>Fuente</th>
              <th>Fecha</th>
            </tr>
          </thead>
          <tbody>
            {recentLeads.map((lead: any) => (
              <tr>
                <td style="font-weight:600;font-size:12px;">{lead.email || <span style="color:#94a3b8;">sin email</span>}</td>
                <td><span style="color:#6366f1;font-size:12px;">{(lead.url || '').replace(/^https?:\/\//,'').slice(0,28)}</span></td>
                <td><span class={`badge ${lead.status || 'new'}`}>{lead.status || 'new'}</span></td>
                <td style="font-size:11px;color:#64748b;">{lead.utm_source || lead.source || '—'}</td>
                <td style="font-size:11px;color:#94a3b8;white-space:nowrap;">{lead.created_at ? new Date(lead.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' }) : '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <div style="text-align:center;padding:32px;color:#94a3b8;font-size:13px;">No hay leads todavia</div>
      )}
    </div>
  </div>

  <!-- ══ Quick access cards ══ -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
    <a href="/admin/crm/leads" class="stat-card" style="text-decoration:none;display:flex;align-items:center;gap:16px;transition:all 0.15s;border-left:3px solid #3b82f6;">
      <div style="width:48px;height:48px;border-radius:12px;background:#eff6ff;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span class="material-symbols-outlined" style="font-size:24px;color:#3b82f6;">person_search</span>
      </div>
      <div>
        <div style="font-size:15px;font-weight:800;color:#1a1a2e;">CRM Leads</div>
        <div style="font-size:12px;color:#64748b;">Filtrar, buscar y gestionar {totalLeads} leads</div>
      </div>
    </a>
    <a href="/admin/crm/clients" class="stat-card" style="text-decoration:none;display:flex;align-items:center;gap:16px;transition:all 0.15s;border-left:3px solid #10b981;">
      <div style="width:48px;height:48px;border-radius:12px;background:#ecfdf5;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span class="material-symbols-outlined" style="font-size:24px;color:#10b981;">business</span>
      </div>
      <div>
        <div style="font-size:15px;font-weight:800;color:#1a1a2e;">CRM Clientes</div>
        <div style="font-size:12px;color:#64748b;">{clients.length} clientes, {payingClients} pagando</div>
      </div>
    </a>
    <a href="/admin/marketing" class="stat-card" style="text-decoration:none;display:flex;align-items:center;gap:16px;transition:all 0.15s;border-left:3px solid #f59e0b;">
      <div style="width:48px;height:48px;border-radius:12px;background:#fffbeb;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span class="material-symbols-outlined" style="font-size:24px;color:#f59e0b;">campaign</span>
      </div>
      <div>
        <div style="font-size:15px;font-weight:800;color:#1a1a2e;">Marketing</div>
        <div style="font-size:12px;color:#64748b;">Nurturing y secuencias email</div>
      </div>
    </a>
  </div>

</AdminLayout>
