---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { listAllClients, getLeadStats, IS_DEMO } from '../../lib/db';

const user = (Astro.locals as any).user;
if (!user || user.role !== 'superuser') return Astro.redirect('/dashboard');

const clients = await listAllClients();
const leadStats = IS_DEMO ? null : await getLeadStats();

// Computed metrics
const totalLeads = leadStats?.total ?? 0;
const leads30d = leadStats?.last30Days ?? 0;
const completedAudits = leadStats?.completed ?? 0;
const registeredUsers = leadStats?.registered ?? 0;
const payingClients = clients.filter((c: any) => c.tier && c.tier !== 'free').length;
const churnedClients = leadStats?.statusBreakdown?.churned ?? 0;

// Conversion rates
const auditToRegister = completedAudits > 0 ? Math.round((registeredUsers / completedAudits) * 100) : 0;
const registerToPay = registeredUsers > 0 ? Math.round((payingClients / registeredUsers) * 100) : 0;
const leadToAudit = totalLeads > 0 ? Math.round((completedAudits / totalLeads) * 100) : 0;

// Funnel data
const funnel = [
  { label: 'Leads', count: totalLeads, color: '#94a3b8' },
  { label: 'Audit completado', count: completedAudits, color: '#3b82f6' },
  { label: 'Registrados', count: registeredUsers, color: '#8b5cf6' },
  { label: 'Pagando', count: payingClients, color: '#10b981' },
  { label: 'Churn', count: churnedClients, color: '#ef4444' },
];
const maxFunnel = Math.max(...funnel.map(f => f.count), 1);

// Recent activity (last 5 leads + last 5 audits)
const recentLeads = leadStats?.recent?.slice(0, 5) ?? [];
---

<AdminLayout title="Metricas" currentPath="/admin">
  <!-- KPI Cards -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:28px;">
    <div class="stat-card">
      <div class="label">Leads totales</div>
      <div class="value">{totalLeads}</div>
      <div class="delta">{leads30d} ultimos 30 dias</div>
    </div>
    <div class="stat-card">
      <div class="label">Auditorias completadas</div>
      <div class="value">{completedAudits}</div>
      <div class="delta">{leadToAudit}% conversion lead→audit</div>
    </div>
    <div class="stat-card">
      <div class="label">Clientes pagando</div>
      <div class="value">{payingClients}</div>
      <div class="delta">{registerToPay}% conv. registro→pago</div>
    </div>
    <div class="stat-card">
      <div class="label">Churn</div>
      <div class="value">{churnedClients}</div>
      <div class="delta down">{payingClients > 0 ? Math.round((churnedClients / (payingClients + churnedClients)) * 100) : 0}% churn rate</div>
    </div>
  </div>

  <!-- Funnel + Conversion -->
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:28px;">
    <!-- Funnel bars -->
    <div class="stat-card">
      <div class="label" style="margin-bottom:16px;">Funnel de conversion</div>
      <div style="display:flex;flex-direction:column;gap:12px;">
        {funnel.map((step) => (
          <div>
            <div style="display:flex;justify-content:space-between;font-size:12px;font-weight:600;color:#334155;margin-bottom:4px;">
              <span>{step.label}</span>
              <span>{step.count}</span>
            </div>
            <div style="height:8px;background:#f1f5f9;border-radius:4px;overflow:hidden;">
              <div style={`width:${Math.max(2, (step.count / maxFunnel) * 100)}%;background:${step.color};height:100%;border-radius:4px;transition:width 0.3s;`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Conversion rates -->
    <div class="stat-card">
      <div class="label" style="margin-bottom:16px;">Tasas de conversion</div>
      <div style="display:flex;flex-direction:column;gap:20px;">
        <div>
          <div style="font-size:11px;color:#64748b;margin-bottom:4px;">Lead → Audit</div>
          <div style="font-size:32px;font-weight:900;color:#3b82f6;">{leadToAudit}%</div>
        </div>
        <div>
          <div style="font-size:11px;color:#64748b;margin-bottom:4px;">Audit → Registro</div>
          <div style="font-size:32px;font-weight:900;color:#8b5cf6;">{auditToRegister}%</div>
        </div>
        <div>
          <div style="font-size:11px;color:#64748b;margin-bottom:4px;">Registro → Pago</div>
          <div style="font-size:32px;font-weight:900;color:#10b981;">{registerToPay}%</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent activity -->
  <div class="stat-card" style="margin-bottom:28px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <div class="label">Actividad reciente</div>
      <a href="/admin/crm/leads" class="btn btn-ghost" style="font-size:12px;padding:6px 12px;">
        Ver todos los leads
        <span class="material-symbols-outlined" style="font-size:14px;">arrow_forward</span>
      </a>
    </div>
    {recentLeads.length > 0 ? (
      <table class="admin-table">
        <thead>
          <tr>
            <th>Email</th>
            <th>URL</th>
            <th>Estado</th>
            <th>Fuente</th>
            <th>Fecha</th>
          </tr>
        </thead>
        <tbody>
          {recentLeads.map((lead: any) => (
            <tr>
              <td style="font-weight:600;">{lead.email || '—'}</td>
              <td><a href={lead.url} target="_blank" style="color:#6366f1;text-decoration:none;">{(lead.url || '').replace('https://','').slice(0,30)}</a></td>
              <td><span class={`badge ${lead.status}`}>{lead.status}</span></td>
              <td style="color:#64748b;">{lead.utm_source || lead.source || '—'}</td>
              <td style="color:#64748b;font-size:12px;">{lead.created_at ? new Date(lead.created_at).toLocaleDateString('es-ES') : '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    ) : (
      <div style="text-align:center;padding:32px;color:#94a3b8;">No hay leads todavia</div>
    )}
  </div>

  <!-- Quick links -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px;">
    <a href="/admin/crm/leads" class="stat-card" style="text-decoration:none;display:flex;align-items:center;gap:14px;">
      <span class="material-symbols-outlined" style="font-size:28px;color:#3b82f6;">person_search</span>
      <div>
        <div style="font-size:14px;font-weight:700;color:#1a1a2e;">CRM Leads</div>
        <div style="font-size:12px;color:#64748b;">Filtrar, buscar y gestionar leads</div>
      </div>
    </a>
    <a href="/admin/crm/clients" class="stat-card" style="text-decoration:none;display:flex;align-items:center;gap:14px;">
      <span class="material-symbols-outlined" style="font-size:28px;color:#10b981;">business</span>
      <div>
        <div style="font-size:14px;font-weight:700;color:#1a1a2e;">CRM Clientes</div>
        <div style="font-size:12px;color:#64748b;">Suscripciones, estado, historial</div>
      </div>
    </a>
    <a href="/admin/marketing" class="stat-card" style="text-decoration:none;display:flex;align-items:center;gap:14px;">
      <span class="material-symbols-outlined" style="font-size:28px;color:#f59e0b;">campaign</span>
      <div>
        <div style="font-size:14px;font-weight:700;color:#1a1a2e;">Marketing</div>
        <div style="font-size:12px;color:#64748b;">Nurturing y secuencias de email</div>
      </div>
    </a>
  </div>
</AdminLayout>
