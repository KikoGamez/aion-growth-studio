---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';

const user = (Astro.locals as any).user;
if (!user || user.role !== 'superuser') return Astro.redirect('/dashboard');

const supabaseUrl = import.meta.env.SUPABASE_URL || process.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY || process.env.SUPABASE_SERVICE_KEY
  || import.meta.env.SUPABASE_SERVICE_ROLE_KEY || process.env.SUPABASE_SERVICE_ROLE_KEY;

let runs: any[] = [];
let fetchError = '';

if (supabaseUrl && supabaseKey) {
  const sb = createClient(supabaseUrl, supabaseKey);
  const days = parseInt(Astro.url.searchParams.get('days') || '7', 10);
  const since = new Date(Date.now() - days * 24 * 60 * 60 * 1000).toISOString();

  const { data, error } = await sb
    .from('audit_runs')
    .select('*')
    .gte('created_at', since)
    .order('created_at', { ascending: false })
    .limit(100);

  if (error) fetchError = error.message;
  else runs = data || [];
}

const avgCoverage = runs.length
  ? Math.round(runs.reduce((s: number, r: any) => s + (r.coverage_pct ?? 0), 0) / runs.length)
  : 0;
const below90 = runs.filter((r: any) => (r.coverage_pct ?? 0) < 90).length;
const avgDuration = runs.length
  ? Math.round(runs.reduce((s: number, r: any) => s + (r.duration_ms ?? 0), 0) / runs.length / 1000)
  : 0;
const avgScore = runs.length
  ? Math.round(runs.reduce((s: number, r: any) => s + (r.score ?? 0), 0) / runs.length)
  : 0;

function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
}
function durationColor(ms: number) {
  const s = ms / 1000;
  if (s < 30) return '#10b981';
  if (s < 120) return '#f59e0b';
  return '#ef4444';
}
---

<AdminLayout title="Diagnosticos" currentPath="/admin/diagnostics">
  {fetchError && (
    <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:12px;padding:14px 18px;margin-bottom:20px;color:#dc2626;font-size:13px;">
      Error: {fetchError}
    </div>
  )}

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px;">
    <div class="stat-card">
      <div class="label">Diagnosticos</div>
      <div class="value">{runs.length}</div>
    </div>
    <div class="stat-card">
      <div class="label">Cobertura media</div>
      <div class="value" style={`color:${avgCoverage >= 90 ? '#10b981' : avgCoverage >= 70 ? '#f59e0b' : '#ef4444'};`}>{avgCoverage}%</div>
    </div>
    <div class="stat-card">
      <div class="label">Por debajo del 90%</div>
      <div class="value" style={`color:${below90 === 0 ? '#10b981' : '#ef4444'};`}>{below90}</div>
    </div>
    <div class="stat-card">
      <div class="label">Duracion media</div>
      <div class="value">{avgDuration}s</div>
    </div>
  </div>

  <!-- Filters -->
  <form method="get" class="filter-bar" style="margin-bottom:24px;">
    <select name="days">
      {[1, 3, 7, 14, 30].map(d => (
        <option value={d} selected={Astro.url.searchParams.get('days') === String(d) || (!Astro.url.searchParams.get('days') && d === 7)}>
          Ultimos {d} dia{d > 1 ? 's' : ''}
        </option>
      ))}
    </select>
    <button type="submit" class="btn btn-primary">Filtrar</button>
    <a href="/admin/diagnostics" class="btn btn-ghost">Reset</a>
  </form>

  <!-- Table -->
  <div class="stat-card" style="padding:0;overflow-x:auto;">
    {runs.length === 0 ? (
      <div style="text-align:center;padding:48px;color:#94a3b8;">
        <span class="material-symbols-outlined" style="font-size:36px;display:block;margin-bottom:8px;">monitor_heart</span>
        Sin diagnosticos en este periodo
      </div>
    ) : (
      <table class="admin-table">
        <thead>
          <tr>
            <th>Dominio</th>
            <th>Fecha</th>
            <th>Cobertura</th>
            <th>Score</th>
            <th>Duracion</th>
            <th>OK</th>
            <th>Fail</th>
            <th>Criticos faltantes</th>
          </tr>
        </thead>
        <tbody>
          {runs.map((r: any) => {
            const cov = r.coverage_pct ?? 0;
            const okCount = (r.modules_ok || []).length;
            const failCount = (r.modules_fail || []).length;
            const critMissing = r.critical_missing || [];
            return (
              <tr>
                <td style="font-weight:700;">
                  <a href={`/admin/audit/${r.audit_id}`} style="color:#6366f1;text-decoration:none;">
                    {r.domain}
                  </a>
                </td>
                <td style="font-size:11px;color:#64748b;white-space:nowrap;">{fmtDate(r.created_at)}</td>
                <td>
                  <div style="display:flex;align-items:center;gap:8px;">
                    <div style="flex:1;max-width:80px;height:6px;background:#f1f5f9;border-radius:3px;overflow:hidden;">
                      <div style={`width:${cov}%;height:100%;background:${cov >= 90 ? '#10b981' : cov >= 70 ? '#f59e0b' : '#ef4444'};border-radius:3px;`}></div>
                    </div>
                    <span style={`font-size:12px;font-weight:700;color:${cov >= 90 ? '#10b981' : cov >= 70 ? '#f59e0b' : '#ef4444'};`}>{cov}%</span>
                  </div>
                </td>
                <td style="font-weight:700;">{r.score ?? '—'}</td>
                <td>
                  <span style={`font-size:12px;font-weight:600;color:${durationColor(r.duration_ms ?? 0)};`}>
                    {r.duration_ms ? Math.round(r.duration_ms / 1000) + 's' : '—'}
                  </span>
                </td>
                <td style="text-align:center;">
                  <span style="font-size:12px;font-weight:700;color:#10b981;">{okCount}</span>
                </td>
                <td style="text-align:center;">
                  {failCount > 0
                    ? <span class="badge churned">{failCount}</span>
                    : <span style="color:#10b981;font-size:12px;">0</span>
                  }
                </td>
                <td>
                  {critMissing.length > 0 ? (
                    <div style="display:flex;flex-wrap:wrap;gap:4px;">
                      {critMissing.map((m: string) => (
                        <span class="badge churned" style="font-size:10px;">{m}</span>
                      ))}
                    </div>
                  ) : (
                    <span style="color:#10b981;display:flex;align-items:center;gap:4px;font-size:12px;">
                      <span class="material-symbols-outlined" style="font-size:14px;">check_circle</span>
                      Completo
                    </span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>

  <!-- Audit debugger -->
  <div class="stat-card" style="margin-top:20px;">
    <div class="label" style="margin-bottom:12px;">Debugger de auditoria</div>
    <form method="get" action="/admin/audit/" style="display:flex;gap:10px;" onsubmit="this.action='/admin/audit/'+this.auditId.value;return true;">
      <input type="text" name="auditId" placeholder="Pega el ID de la auditoria..." style="flex:1;padding:8px 14px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:inherit;" />
      <button type="submit" class="btn btn-primary">
        <span class="material-symbols-outlined" style="font-size:16px;">bug_report</span>
        Inspeccionar
      </button>
    </form>
  </div>
</AdminLayout>
