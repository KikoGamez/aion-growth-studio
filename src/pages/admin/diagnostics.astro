---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';

const user = (Astro.locals as any).user;
if (!user || user.role !== 'superuser') return Astro.redirect('/dashboard');

const supabaseUrl = import.meta.env.SUPABASE_URL || process.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY || process.env.SUPABASE_SERVICE_KEY
  || import.meta.env.SUPABASE_SERVICE_ROLE_KEY || process.env.SUPABASE_SERVICE_ROLE_KEY;

let runs: any[] = [];
let fetchError = '';

if (supabaseUrl && supabaseKey) {
  const sb = createClient(supabaseUrl, supabaseKey);
  const days = parseInt(Astro.url.searchParams.get('days') || '7', 10);
  const since = new Date(Date.now() - days * 24 * 60 * 60 * 1000).toISOString();

  const { data, error } = await sb
    .from('audit_runs')
    .select('*')
    .gte('created_at', since)
    .order('created_at', { ascending: false })
    .limit(100);

  if (error) fetchError = error.message;
  else runs = data || [];
}

const avgCoverage = runs.length
  ? Math.round(runs.reduce((s: number, r: any) => s + (r.coverage_pct ?? 0), 0) / runs.length)
  : 0;
const below90 = runs.filter((r: any) => (r.coverage_pct ?? 0) < 90).length;
const avgDuration = runs.length
  ? Math.round(runs.reduce((s: number, r: any) => s + (r.duration_ms ?? 0), 0) / runs.length / 1000)
  : 0;
const avgScore = runs.length
  ? Math.round(runs.reduce((s: number, r: any) => s + (r.score ?? 0), 0) / runs.length)
  : 0;

function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
}
function durationColor(ms: number) {
  const s = ms / 1000;
  if (s < 30) return '#10b981';
  if (s < 120) return '#f59e0b';
  return '#ef4444';
}
---

<AdminLayout title="Diagnosticos" currentPath="/admin/diagnostics">
  <!-- Header -->
  <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:40px;">
    <div>
      <h2 class="font-headline" style="font-size:28px;font-weight:800;letter-spacing:-0.03em;color:#191c1e;">Diagnosticos</h2>
      <p style="color:#505f76;margin-top:4px;font-size:14px;">Monitor de ejecucion y cobertura del pipeline.</p>
    </div>
  </div>

  {fetchError && (
    <div style="background:#ffdad6;border-radius:12px;padding:14px 18px;margin-bottom:20px;color:#ba1a1a;font-size:13px;">
      Error: {fetchError}
    </div>
  )}

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:32px;">
    <div style="background:white;border-radius:14px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.07),0 0 0 1px rgba(0,0,0,0.04);">
      <div class="label">Diagnosticos</div>
      <div class="value">{runs.length}</div>
    </div>
    <div style="background:white;border-radius:14px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.07),0 0 0 1px rgba(0,0,0,0.04);">
      <div class="label">Cobertura media</div>
      <div class="value" style={`color:${avgCoverage >= 90 ? '#003d27' : avgCoverage >= 70 ? '#505f76' : '#ba1a1a'};`}>{avgCoverage}%</div>
    </div>
    <div style="background:white;border-radius:14px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.07),0 0 0 1px rgba(0,0,0,0.04);">
      <div class="label">Por debajo del 90%</div>
      <div class="value" style={`color:${below90 === 0 ? '#003d27' : '#ba1a1a'};`}>{below90}</div>
    </div>
    <div style="background:white;border-radius:14px;padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.07),0 0 0 1px rgba(0,0,0,0.04);">
      <div class="label">Duracion media</div>
      <div class="value">{avgDuration}s</div>
    </div>
  </div>

  <!-- Filters -->
  <form method="get" style="background:white;padding:20px 24px;border-radius:14px;margin-bottom:32px;display:flex;flex-wrap:wrap;align-items:center;gap:16px;box-shadow:0 2px 8px rgba(0,0,0,0.07),0 0 0 1px rgba(0,0,0,0.04);">
    <div style="position:relative;">
      <select name="days" style="appearance:none;background:#f2f4f6;border:none;border-radius:12px;padding:10px 40px 10px 16px;font-size:13px;font-family:inherit;font-weight:500;color:#444653;outline:none;cursor:pointer;">
        {[1, 3, 7, 14, 30].map(d => (
          <option value={d} selected={Astro.url.searchParams.get('days') === String(d) || (!Astro.url.searchParams.get('days') && d === 7)}>
            Ultimos {d} dia{d > 1 ? 's' : ''}
          </option>
        ))}
      </select>
      <span class="material-symbols-outlined" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);color:#757684;pointer-events:none;font-size:18px;">expand_more</span>
    </div>
    <button type="submit" style="display:flex;align-items:center;gap:8px;background:#e6e8ea;color:#191c1e;padding:10px 20px;border-radius:12px;border:none;font-size:13px;font-weight:600;font-family:inherit;cursor:pointer;">
      <span class="material-symbols-outlined" style="font-size:18px;">filter_list</span> Filtrar
    </button>
    <a href="/admin/diagnostics" style="color:#00288e;font-size:13px;font-weight:600;text-decoration:none;">Reset</a>
  </form>

  <!-- Table -->
  <div style="background:white;border-radius:14px;overflow-x:auto;box-shadow:0 2px 8px rgba(0,0,0,0.07),0 0 0 1px rgba(0,0,0,0.04);">
    {runs.length === 0 ? (
      <div style="text-align:center;padding:48px;color:#505f76;">
        <span class="material-symbols-outlined" style="font-size:36px;display:block;margin-bottom:8px;color:#c4c5d5;">monitor_heart</span>
        Sin diagnosticos en este periodo
      </div>
    ) : (
      <table style="width:100%;border-collapse:collapse;text-align:left;">
        <thead>
          <tr style="background:#f2f4f6;">
            <th style="padding:16px 24px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#444653;font-family:'Manrope',sans-serif;">Dominio</th>
            <th style="padding:16px 16px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#444653;font-family:'Manrope',sans-serif;">Fecha</th>
            <th style="padding:16px 16px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#444653;font-family:'Manrope',sans-serif;">Cobertura</th>
            <th style="padding:16px 16px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#444653;font-family:'Manrope',sans-serif;">Score</th>
            <th style="padding:16px 16px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#444653;font-family:'Manrope',sans-serif;">Duracion</th>
            <th style="padding:16px 12px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#444653;font-family:'Manrope',sans-serif;">OK</th>
            <th style="padding:16px 12px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#444653;font-family:'Manrope',sans-serif;">Fail</th>
            <th style="padding:16px 16px;font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;color:#444653;font-family:'Manrope',sans-serif;">Criticos faltantes</th>
          </tr>
        </thead>
        <tbody>
          {runs.map((r: any) => {
            const cov = r.coverage_pct ?? 0;
            const okCount = (r.modules_ok || []).length;
            const failCount = (r.modules_fail || []).length;
            const critMissing = r.critical_missing || [];
            return (
              <tr style="border-top:1px solid rgba(196,197,213,0.1);transition:background 0.15s;" onmouseenter="this.style.background='#f7f9fb'" onmouseleave="this.style.background=''">
                <td style="padding:16px 24px;font-weight:700;">
                  <a href={`/admin/audit/${r.audit_id}`} style="color:#00288e;text-decoration:none;font-size:14px;">
                    {r.domain}
                  </a>
                </td>
                <td style="padding:16px 16px;font-size:12px;color:#505f76;white-space:nowrap;">{fmtDate(r.created_at)}</td>
                <td style="padding:16px 16px;">
                  <div style="display:flex;align-items:center;gap:8px;">
                    <div style="flex:1;max-width:80px;height:8px;background:#eceef0;border-radius:99px;overflow:hidden;">
                      <div style={`width:${cov}%;height:100%;background:${cov >= 90 ? '#003d27' : cov >= 70 ? '#505f76' : '#ba1a1a'};border-radius:99px;`}></div>
                    </div>
                    <span style={`font-size:13px;font-weight:700;color:${cov >= 90 ? '#003d27' : cov >= 70 ? '#505f76' : '#ba1a1a'};`}>{cov}%</span>
                  </div>
                </td>
                <td style="padding:16px 16px;font-weight:700;font-size:14px;">{r.score ?? '—'}</td>
                <td style="padding:16px 16px;">
                  <span style={`font-size:13px;font-weight:600;color:${durationColor(r.duration_ms ?? 0)};`}>
                    {r.duration_ms ? Math.round(r.duration_ms / 1000) + 's' : '—'}
                  </span>
                </td>
                <td style="padding:16px 12px;text-align:center;">
                  <span style="font-size:13px;font-weight:700;color:#003d27;">{okCount}</span>
                </td>
                <td style="padding:16px 12px;text-align:center;">
                  {failCount > 0
                    ? <span style="display:inline-flex;padding:3px 10px;border-radius:99px;font-size:10px;font-weight:700;background:#ffdad6;color:#ba1a1a;">{failCount}</span>
                    : <span style="color:#003d27;font-size:13px;">0</span>
                  }
                </td>
                <td style="padding:16px 16px;">
                  {critMissing.length > 0 ? (
                    <div style="display:flex;flex-wrap:wrap;gap:4px;">
                      {critMissing.map((m: string) => (
                        <span style="display:inline-flex;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;background:#ffdad6;color:#ba1a1a;">{m}</span>
                      ))}
                    </div>
                  ) : (
                    <span style="color:#003d27;display:flex;align-items:center;gap:4px;font-size:12px;font-weight:600;">
                      <span class="material-symbols-outlined" style="font-size:14px;">check_circle</span>
                      Completo
                    </span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>

  <!-- Audit debugger -->
  <div style="background:white;border-radius:14px;padding:24px;margin-top:32px;box-shadow:0 2px 8px rgba(0,0,0,0.07),0 0 0 1px rgba(0,0,0,0.04);">
    <div class="label" style="margin-bottom:12px;">Debugger de auditoria</div>
    <form method="get" action="/admin/audit/" style="display:flex;gap:12px;" onsubmit="this.action='/admin/audit/'+this.auditId.value;return true;">
      <div style="flex:1;position:relative;">
        <span class="material-symbols-outlined" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#757684;font-size:18px;">bug_report</span>
        <input type="text" name="auditId" placeholder="Pega el ID de la auditoria..." style="width:100%;padding:10px 14px 10px 44px;background:#f2f4f6;border:none;border-radius:12px;font-size:13px;font-family:inherit;color:#191c1e;outline:none;" />
      </div>
      <button type="submit" class="btn btn-primary" style="padding:10px 20px;">
        Inspeccionar
      </button>
    </form>
  </div>
</AdminLayout>
