---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { createClient } from '@supabase/supabase-js';

const user = (Astro.locals as any).user;
if (!user || user.role !== 'superuser') return Astro.redirect('/dashboard');

const supabaseUrl = import.meta.env.SUPABASE_URL || process.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_SERVICE_KEY || process.env.SUPABASE_SERVICE_KEY
  || import.meta.env.SUPABASE_SERVICE_ROLE_KEY || process.env.SUPABASE_SERVICE_ROLE_KEY;

let evaluations: any[] = [];
let fetchError = '';

if (supabaseUrl && supabaseKey) {
  const sb = createClient(supabaseUrl, supabaseKey);
  const days = parseInt(Astro.url.searchParams.get('days') || '7', 10);
  const since = new Date(Date.now() - days * 24 * 60 * 60 * 1000).toISOString();
  const sector = Astro.url.searchParams.get('sector') || '';
  const minScore = parseFloat(Astro.url.searchParams.get('min') || '0');

  let q = sb
    .from('qa_quality_evaluations')
    .select('id, domain, sector, audit_score, overall, clarity, credibility, actionability, urgency, willingness_to_pay, would_send_to_ceo, would_subscribe, ceo_reason, subscribe_reason, errors, not_interesting, best_part, worst_part, prompt_for_claude_code, created_at')
    .gte('created_at', since)
    .order('created_at', { ascending: false });

  if (sector) q = q.eq('sector', sector);
  if (minScore > 0) q = q.gte('overall', minScore);

  const { data, error } = await q.limit(100);
  if (error) fetchError = error.message;
  else evaluations = data || [];
}

// Load existing fixes to show status on each evaluation
let fixesByEvalId = new Map<string, any>();
if (supabaseUrl && supabaseKey && evaluations.length > 0) {
  try {
    const sb = createClient(supabaseUrl, supabaseKey);
    const evalIds = evaluations.map((e: any) => e.id);
    const { data: fixes } = await sb.from('qa_fixes')
      .select('id, evaluation_id, status, applied_at, score_before, score_after, delta')
      .in('evaluation_id', evalIds);
    for (const f of (fixes || [])) {
      fixesByEvalId.set(f.evaluation_id, f);
    }
  } catch { /* table may not exist yet — graceful */ }
}

const uniqueSectors = [...new Set(evaluations.map((e: any) => e.sector).filter(Boolean))].sort();
const avgOverall = evaluations.length
  ? (evaluations.reduce((s: number, e: any) => s + (e.overall ?? 0), 0) / evaluations.length).toFixed(1)
  : '—';
const ceoCount = evaluations.filter((e: any) => e.would_send_to_ceo).length;
const subCount = evaluations.filter((e: any) => e.would_subscribe).length;
const appliedFixes = [...fixesByEvalId.values()].filter((f: any) => f.status === 'applied' || f.status === 'verified').length;

function scoreColor(s: number) {
  if (s >= 7) return '#10b981';
  if (s >= 5) return '#f59e0b';
  return '#ef4444';
}
function fmtDate(iso: string) {
  return new Date(iso).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });
}
---

<AdminLayout title="QA Engine" currentPath="/admin/qa">
  {fetchError && (
    <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:12px;padding:14px 18px;margin-bottom:20px;color:#dc2626;font-size:13px;">
      Error cargando datos: {fetchError}
    </div>
  )}

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px;">
    <div class="stat-card">
      <div class="label">Score medio</div>
      <div class="value" style={`color:${scoreColor(parseFloat(avgOverall as string) || 0)}`}>{avgOverall}</div>
    </div>
    <div class="stat-card">
      <div class="label">Evaluaciones</div>
      <div class="value">{evaluations.length}</div>
    </div>
    <div class="stat-card">
      <div class="label">Enviaria al CEO</div>
      <div class="value" style="color:#6366f1;">{ceoCount}</div>
    </div>
    <div class="stat-card">
      <div class="label">Pagaria</div>
      <div class="value" style="color:#10b981;">{subCount}</div>
    </div>
    <div class="stat-card">
      <div class="label">Fixes aplicados</div>
      <div class="value" style="color:#8b5cf6;">{appliedFixes}</div>
    </div>
  </div>

  <!-- Filters -->
  <form method="get" class="filter-bar" style="margin-bottom:24px;">
    <select name="days">
      {[1, 3, 7, 14, 30].map(d => (
        <option value={d} selected={Astro.url.searchParams.get('days') === String(d) || (!Astro.url.searchParams.get('days') && d === 7)}>
          Ultimos {d} dia{d > 1 ? 's' : ''}
        </option>
      ))}
    </select>
    <select name="sector">
      <option value="">Todos los sectores</option>
      {uniqueSectors.map(s => (
        <option value={s} selected={Astro.url.searchParams.get('sector') === s}>{s}</option>
      ))}
    </select>
    <input type="number" name="min" min="0" max="10" step="0.5" value={Astro.url.searchParams.get('min') || ''} placeholder="Score min" style="width:100px;" />
    <button type="submit" class="btn btn-primary">Filtrar</button>
    {(Astro.url.searchParams.get('sector') || Astro.url.searchParams.get('min')) && (
      <a href="/admin/qa" class="btn btn-ghost">Limpiar</a>
    )}
  </form>

  <!-- Table -->
  <div class="stat-card" style="padding:0;overflow-x:auto;">
    {evaluations.length === 0 ? (
      <div style="text-align:center;padding:48px;color:#94a3b8;">
        <span class="material-symbols-outlined" style="font-size:36px;display:block;margin-bottom:8px;">verified</span>
        Sin evaluaciones en el periodo seleccionado
      </div>
    ) : (
      <table class="admin-table">
        <thead>
          <tr>
            <th>Dominio</th>
            <th>Sector</th>
            <th>Score</th>
            <th>Claridad</th>
            <th>Credibilidad</th>
            <th>Accionable</th>
            <th>CEO?</th>
            <th>Paga?</th>
            <th>Errores</th>
            <th>Fecha</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {evaluations.map((e: any, idx: number) => {
            const overall = e.overall ?? 0;
            const errCount = (e.errors || []).length;
            const niCount = (e.not_interesting || []).length;
            return (
              <>
                <tr id={`row-${idx}`}>
                  <td>
                    <div style="font-weight:700;font-size:13px;">{e.domain}</div>
                    {e.prompt_for_claude_code && <span class="badge" style="background:#fef2f2;color:#dc2626;margin-top:3px;">fix propuesto</span>}
                  </td>
                  <td style="font-size:12px;color:#64748b;">{e.sector}</td>
                  <td>
                    <div style={`display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:10px;background:${scoreColor(overall)}15;font-weight:900;font-size:14px;color:${scoreColor(overall)};`}>
                      {overall.toFixed(1)}
                    </div>
                  </td>
                  <td style={`font-weight:700;color:${scoreColor(e.clarity ?? 0)};`}>{(e.clarity ?? 0).toFixed(1)}</td>
                  <td style={`font-weight:700;color:${scoreColor(e.credibility ?? 0)};`}>{(e.credibility ?? 0).toFixed(1)}</td>
                  <td style={`font-weight:700;color:${scoreColor(e.actionability ?? 0)};`}>{(e.actionability ?? 0).toFixed(1)}</td>
                  <td><span class={`badge ${e.would_send_to_ceo ? 'paying' : 'churned'}`}>{e.would_send_to_ceo ? 'Si' : 'No'}</span></td>
                  <td><span class={`badge ${e.would_subscribe ? 'paying' : 'churned'}`}>{e.would_subscribe ? 'Si' : 'No'}</span></td>
                  <td>
                    {errCount > 0 && <span class="badge churned">{errCount}</span>}
                    {niCount > 0 && <span class="badge audit_started" style="margin-left:4px;">{niCount} NI</span>}
                    {errCount === 0 && niCount === 0 && <span style="color:#10b981;">
                      <span class="material-symbols-outlined" style="font-size:16px;">check_circle</span>
                    </span>}
                  </td>
                  <td style="font-size:11px;color:#94a3b8;white-space:nowrap;">{fmtDate(e.created_at)}</td>
                  <td>
                    <button class="btn btn-ghost" style="font-size:11px;padding:4px 10px;" onclick={`toggleDetail(${idx})`} id={`btn-${idx}`}>
                      <span class="material-symbols-outlined" style="font-size:14px;">expand_more</span>
                    </button>
                  </td>
                </tr>
                <tr id={`detail-${idx}`} style="display:none;">
                  <td colspan="11" style="padding:4px 14px 20px;background:#f8fafc;">
                    <!-- Score breakdown -->
                    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:16px;">
                      {[
                        ['Claridad', e.clarity],
                        ['Credibilidad', e.credibility],
                        ['Accionable', e.actionability],
                        ['Urgencia', e.urgency],
                        ['Pagaria', e.willingness_to_pay],
                      ].map(([lbl, val]: any) => (
                        <div style="background:white;border-radius:10px;padding:12px;text-align:center;border:1px solid #f0f0f0;">
                          <div style={`font-size:22px;font-weight:900;color:${scoreColor(val ?? 0)};`}>{(val ?? 0).toFixed(1)}</div>
                          <div style="font-size:10px;color:#64748b;margin-top:2px;text-transform:uppercase;letter-spacing:0.04em;">{lbl}</div>
                        </div>
                      ))}
                    </div>

                    {e.ceo_reason && <div style="font-size:12px;margin-bottom:8px;"><strong>CEO ({e.would_send_to_ceo ? '✓' : '✗'}):</strong> {e.ceo_reason}</div>}
                    {e.subscribe_reason && <div style="font-size:12px;margin-bottom:8px;"><strong>Pagaria ({e.would_subscribe ? '✓' : '✗'}):</strong> {e.subscribe_reason}</div>}
                    {e.best_part && <div style="font-size:12px;color:#10b981;margin-bottom:4px;"><strong>Lo mejor:</strong> {e.best_part}</div>}
                    {e.worst_part && <div style="font-size:12px;color:#ef4444;margin-bottom:12px;"><strong>Lo peor:</strong> {e.worst_part}</div>}

                    {(e.errors || []).length > 0 && (
                      <div style="margin-bottom:12px;">
                        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#64748b;margin-bottom:8px;">Errores del sistema</div>
                        {(e.errors as any[]).map((err: any) => (
                          <div style="background:#fef2f2;border-radius:8px;padding:10px 14px;margin-bottom:6px;border-left:3px solid #ef4444;">
                            <div style="font-size:11px;font-weight:700;color:#ef4444;text-transform:uppercase;">{err.severity} <span style="color:#94a3b8;font-weight:500;">· {err.section}</span></div>
                            <div style="font-size:13px;margin:4px 0;">{err.issue}</div>
                            <div style="font-size:12px;color:#64748b;">→ {err.what_should_change}</div>
                          </div>
                        ))}
                      </div>
                    )}

                    {(e.not_interesting || []).length > 0 && (
                      <div style="margin-bottom:12px;">
                        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#64748b;margin-bottom:8px;">No interesa (producto)</div>
                        {(e.not_interesting as any[]).map((ni: any) => (
                          <div style="background:#fffbeb;border-radius:8px;padding:10px 14px;margin-bottom:6px;border-left:3px solid #f59e0b;">
                            <div style="font-size:11px;color:#94a3b8;">{ni.section}</div>
                            <div style="font-size:13px;margin:4px 0;">{ni.issue}</div>
                            <div style="font-size:12px;color:#64748b;">→ {ni.suggestion}</div>
                          </div>
                        ))}
                      </div>
                    )}

                    {e.prompt_for_claude_code && (() => {
                      const fix = fixesByEvalId.get(e.id);
                      const isApplied = fix?.status === 'applied' || fix?.status === 'verified';
                      return (
                      <div style="background:#eef2ff;border-radius:10px;padding:16px;margin-top:12px;">
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                          <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#6366f1;">Prompt para Claude Code</div>
                          {isApplied ? (
                            <span class="badge paying" style="font-size:11px;">
                              <span class="material-symbols-outlined" style="font-size:14px;">check</span>
                              Aplicado {fix.applied_at ? new Date(fix.applied_at).toLocaleDateString('es-ES', { day: '2-digit', month: 'short' }) : ''}
                              {fix.delta != null && (
                                <span style={`margin-left:6px;color:${fix.delta > 0 ? '#10b981' : fix.delta < 0 ? '#ef4444' : '#94a3b8'};`}>
                                  {fix.delta > 0 ? '+' : ''}{fix.delta.toFixed(1)}
                                </span>
                              )}
                            </span>
                          ) : (
                            <span class="badge audit_started" style="font-size:11px;">Pendiente</span>
                          )}
                        </div>
                        <pre id={`prompt-${e.id}`} style="background:white;border-radius:8px;padding:14px;font-size:12px;white-space:pre-wrap;word-break:break-word;max-height:300px;overflow-y:auto;border:1px solid #e0e7ff;">{e.prompt_for_claude_code}</pre>
                        <div style="display:flex;gap:8px;margin-top:8px;">
                          <button class="btn btn-primary" style="font-size:12px;" onclick={`copyPrompt('${e.id}')`}>
                            <span class="material-symbols-outlined" style="font-size:14px;">content_copy</span>
                            Copiar
                          </button>
                          {!isApplied && (
                            <button class="btn btn-ghost" style="font-size:12px;" onclick={`markApplied('${e.id}')`} id={`apply-btn-${e.id}`}>
                              <span class="material-symbols-outlined" style="font-size:14px;">check_circle</span>
                              Marcar como aplicado
                            </button>
                          )}
                        </div>
                      </div>
                      );
                    })()}
                  </td>
                </tr>
              </>
            );
          })}
        </tbody>
      </table>
    )}
  </div>

  <script is:inline>
    function toggleDetail(idx) {
      var row = document.getElementById('detail-' + idx);
      if (!row) return;
      var isHidden = row.style.display === 'none';
      row.style.display = isHidden ? 'table-row' : 'none';
      var btn = document.getElementById('btn-' + idx);
      if (btn) btn.querySelector('.material-symbols-outlined').textContent = isHidden ? 'expand_less' : 'expand_more';
    }
    function copyPrompt(id) {
      var el = document.getElementById('prompt-' + id);
      if (!el) return;
      navigator.clipboard.writeText(el.textContent || '').then(function() {
        var container = el.parentElement;
        var copyBtn = container.querySelector('.btn-primary');
        if (copyBtn) { var o = copyBtn.innerHTML; copyBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px;">check</span> Copiado'; setTimeout(function() { copyBtn.innerHTML = o; }, 2000); }
      });
    }
    function markApplied(evalId) {
      var btn = document.getElementById('apply-btn-' + evalId);
      if (!btn) return;
      var commitSha = prompt('Commit SHA (opcional, deja vacio si no aplica):');
      if (commitSha === null) return; // cancelled
      btn.disabled = true;
      btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px;">hourglass_top</span> Guardando...';
      fetch('/api/admin/qa-fix', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'mark-applied', evaluationId: evalId, commitSha: commitSha || undefined }),
      }).then(function(res) { return res.json(); }).then(function(data) {
        if (data.ok) {
          btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px;">check_circle</span> Aplicado';
          btn.style.background = '#ecfdf5';
          btn.style.color = '#10b981';
          btn.style.borderColor = '#10b981';
        } else {
          btn.innerHTML = 'Error';
          btn.disabled = false;
        }
      }).catch(function() {
        btn.innerHTML = 'Error';
        btn.disabled = false;
      });
    }
  </script>
</AdminLayout>
