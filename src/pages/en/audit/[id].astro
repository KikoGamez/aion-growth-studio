---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { getAuditPage } from '../../../lib/audit/notion';

const { id } = Astro.params;
const lang = 'en';

let auditUrl = '';
let initialStatus = 'processing';

if (id) {
  try {
    const audit = await getAuditPage(id);
    auditUrl = audit.url;
    initialStatus = audit.status;
  } catch {
    // Page not found or Notion error — show loading state
  }
}

const domain = auditUrl ? new URL(auditUrl).hostname.replace(/^www\./, '') : '';

const MODULES = [
  { key: 'crawl',       label: 'Technical SEO Analysis' },
  { key: 'ssl',         label: 'SSL/HTTPS Security' },
  { key: 'pagespeed',   label: 'Web Performance (PageSpeed)' },
  { key: 'sector',      label: 'Sector Detection' },
  { key: 'content',     label: 'Content Analysis' },
  { key: 'geo',         label: 'AI Visibility (GEO)' },
  { key: 'gbp',         label: 'Google Business Profile' },
  { key: 'traffic',     label: 'Estimated Traffic' },
  { key: 'seo',         label: 'Organic SEO and Backlinks' },
  { key: 'seo_pages',   label: 'Top Organic Pages' },
  { key: 'competitors',        label: 'Competitor Analysis' },
  { key: 'competitor_traffic', label: 'Competitor Traffic Analysis' },
  { key: 'keyword_gap',        label: 'Keyword Gap vs Competitors' },
  { key: 'instagram',          label: 'Instagram and Social Media' },
  { key: 'linkedin',    label: 'LinkedIn Company Page' },
  { key: 'techstack',   label: 'Tech Stack and Measurement' },
  { key: 'conversion',  label: 'Conversion Capability' },
  { key: 'score',       label: 'Final Score' },
  { key: 'insights',    label: 'Executive Diagnosis' },
];
---

<Layout
  title={`Analyzing ${domain || 'your website'} — AION`}
  description="Digital visibility analysis in progress"
  lang={lang}
>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<style>
  :root {
    --surface: #f7f9ff;
    --surface-low: #edf4ff;
    --surface-high: #d8eaff;
    --primary: #000e41;
    --primary-cont: #001f70;
    --on-surface: #001d32;
    --on-surface-var: #43474d;
    --tertiary-fixed: #69ff87;
    --shadow: 0 12px 40px rgba(0,29,50,0.06);
  }
  *, *::before, *::after { box-sizing: border-box; }
  body { background: var(--surface) !important; color: var(--on-surface); font-family: 'Inter', system-ui, sans-serif; margin: 0; }

  .audit-shell {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 100vh;
    background: var(--surface);
  }
  .audit-sidebar {
    background: var(--surface-low);
    padding: 2rem 1.5rem;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  .audit-main {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 3.5rem 3rem;
    background: var(--surface);
  }
  .mod-nav-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.4375rem 0.625rem;
    border-radius: 0.375rem;
    color: var(--on-surface-var);
    font-size: 0.8125rem;
    transition: background 0.2s, color 0.2s;
  }
  .mod-nav-item.running {
    background: var(--surface-high);
    color: var(--primary);
    font-weight: 600;
  }
  .mod-nav-item.done { color: #1a6b00; }
  .mod-nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(195,198,206,0.5);
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .mod-nav-item.running .mod-nav-dot { background: var(--primary); }
  .mod-nav-item.done    .mod-nav-dot { background: #22c55e; }
  .proc-card {
    background: #fff;
    border-radius: 1rem;
    box-shadow: var(--shadow);
    padding: 2.5rem;
    width: 100%;
    max-width: 540px;
  }
  .mod-spinner {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--surface-high);
    border-top-color: var(--primary);
    animation: spin 0.8s linear infinite;
    flex-shrink: 0;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.6; }
  }
  @media (max-width: 768px) {
    .audit-shell { grid-template-columns: 1fr; }
    .audit-sidebar {
      height: auto;
      position: relative;
      padding: 1rem 1.25rem;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.75rem;
    }
    .sidebar-modules-nav { display: none !important; }
    .sidebar-domain-block { margin-bottom: 0 !important; }
    .audit-main { padding: 1.5rem 1.25rem; }
    .proc-card { padding: 1.75rem 1.25rem; }
  }
</style>

  <div class="audit-shell">

    <!-- ═══ LEFT SIDEBAR ═══ -->
    <aside class="audit-sidebar">
      <div class="sidebar-domain-block" style="margin-bottom:1.75rem;">
        <a href="/en/" style="display:inline-block;margin-bottom:0.75rem;">
          <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:1.75rem;width:auto;" />
        </a>
        <p style="font-size:0.6875rem;font-weight:600;color:var(--on-surface-var);text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.25rem;">Analyzing</p>
        <p style="font-size:0.875rem;font-weight:700;color:var(--primary);word-break:break-all;margin:0;">{domain || auditUrl || '—'}</p>
      </div>

      <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0 0 1rem;">
        <span id="sidebar-count">0</span> / {MODULES.length} modules
      </p>

      <nav class="sidebar-modules-nav" style="flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:0.0625rem;">
        {MODULES.map(m => (
          <div class="mod-nav-item" id={`nav-${m.key}`}>
            <span class="mod-nav-dot"></span>
            <span>{m.label}</span>
          </div>
        ))}
      </nav>

      <div id="sidebar-cta" style="display:none;margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid rgba(195,198,206,0.3);">
        <a id="sidebar-report-link" href="#"
          style="display:block;background:var(--tertiary-fixed);color:#001905;border-radius:0.375rem;padding:0.75rem 1rem;font-weight:700;font-size:0.875rem;text-align:center;text-decoration:none;">
          View full report →
        </a>
      </div>
    </aside>

    <!-- ═══ MAIN CONTENT ═══ -->
    <main class="audit-main">
      <div style="width:100%;max-width:540px;">

        <!-- PROCESSING CARD -->
        <div id="proc-card" class="proc-card">
          <div style="margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
              <div style="width:8px;height:8px;border-radius:50%;background:var(--primary);animation:pulse-dot 1.2s ease-in-out infinite;flex-shrink:0;"></div>
              <p style="font-size:0.6875rem;font-weight:600;color:var(--on-surface-var);text-transform:uppercase;letter-spacing:0.06em;margin:0;">Analysis in progress</p>
            </div>
            <h1 style="font-size:1.375rem;font-weight:800;color:var(--primary);margin:0 0 0.25rem;line-height:1.25;">Analyzing your digital presence</h1>
            {domain && <p style="font-size:0.8125rem;color:var(--on-surface-var);font-family:monospace;margin:0;">{domain}</p>}
          </div>

          <div style="margin-bottom:1.5rem;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.375rem;">
              <p id="progress-narrative" style="font-size:0.8125rem;color:var(--on-surface-var);margin:0;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;transition:opacity 0.3s;"></p>
              <span id="progress-pct" style="font-size:0.8125rem;color:var(--primary);font-weight:600;font-variant-numeric:tabular-nums;margin-left:0.75rem;flex-shrink:0;">0%</span>
            </div>
            <div style="height:4px;background:var(--surface-low);border-radius:9999px;overflow:hidden;">
              <div id="progress-bar" style="height:100%;width:0;background:linear-gradient(90deg,var(--primary),#1a4bcc);transition:width 0.7s ease;border-radius:9999px;"></div>
            </div>
          </div>

          <div id="current-module" style="display:flex;align-items:center;gap:0.625rem;background:var(--surface-low);border-radius:0.5rem;padding:0.75rem 1rem;">
            <span class="mod-spinner"></span>
            <span id="current-module-label" style="font-size:0.875rem;color:var(--primary);font-weight:500;">Starting…</span>
          </div>
        </div>

        <!-- COMPLETION CARD -->
        <div id="complete-card" style="display:none;background:#fff;border-radius:1rem;box-shadow:var(--shadow);padding:2.5rem;margin-top:1.25rem;text-align:center;">
          <div style="width:3rem;height:3rem;border-radius:50%;background:#e6ffd4;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.25rem;font-weight:700;color:#1a6b00;">✓</div>
          <p style="font-size:1.125rem;font-weight:700;color:var(--primary);margin:0 0 0.5rem;">Analysis complete!</p>
          <p style="color:var(--on-surface-var);margin:0 0 1.5rem;font-size:0.9rem;">Your report is ready.</p>
          <a id="report-btn" href="#"
            style="display:inline-block;background:var(--tertiary-fixed);color:#001905;border-radius:0.375rem;padding:0.875rem 2rem;font-weight:700;text-decoration:none;font-size:0.9375rem;">
            View full report →
          </a>
        </div>

        <!-- ERROR STATE -->
        <div id="error-state" style="display:none;text-align:center;padding:4rem 2rem;">
          <div style="width:3.5rem;height:3.5rem;margin:0 auto 1rem;border-radius:50%;background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);display:flex;align-items:center;justify-content:center;">
            <svg width="24" height="24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <h2 style="font-size:1.125rem;font-weight:700;color:var(--primary);margin:0 0 0.5rem;">Analysis could not be completed</h2>
          <p style="color:var(--on-surface-var);font-size:0.9rem;margin:0 0 1.5rem;">An error occurred while analyzing your website. Please try again.</p>
          <a href="/en/diagnostic"
            style="display:inline-block;background:var(--primary);color:#fff;border-radius:0.375rem;padding:0.75rem 1.5rem;font-weight:600;text-decoration:none;font-size:0.9rem;">
            New analysis
          </a>
        </div>

      </div>
    </main>
  </div>

</Layout>

<script define:vars={{ auditId: id, initialStatus, domain }}>
  const MODULES = [
    'crawl', 'ssl', 'pagespeed', 'sector', 'content', 'geo', 'gbp', 'traffic', 'seo', 'seo_pages', 'competitors', 'competitor_traffic', 'keyword_gap', 'instagram', 'linkedin', 'techstack', 'conversion', 'score', 'insights'
  ];

  const MODULE_NARRATIVE = {
    crawl:               'Scanning technical structure and content signals…',
    ssl:                 'Verifying domain security certificate…',
    pagespeed:           'Measuring load speed — every second matters for SEO…',
    sector:              'Identifying sector and market positioning…',
    content:             'Analyzing value proposition and message clarity…',
    geo:                 'Testing visibility in ChatGPT, Perplexity and other AI engines…',
    gbp:                 'Finding and auditing Google Business Profile…',
    traffic:             'Estimating traffic volume and annual trend…',
    seo:                 'Counting keywords in Google top 10 and measuring domain authority…',
    seo_pages:           'Identifying pages generating the most organic traffic…',
    competitors:         'Mapping the competitive landscape…',
    competitor_traffic:  'Comparing your traffic and keywords with direct competitors…',
    keyword_gap:         'Finding where competitors rank but you don\'t…',
    instagram:           'Analyzing social media presence and engagement…',
    linkedin:            'Auditing professional authority on LinkedIn…',
    techstack:           'Detecting marketing, analytics and conversion tools…',
    conversion:          'Evaluating lead capture and conversion funnel…',
    score:               'Calculating digital health score…',
    insights:            'Generating personalized executive diagnosis…',
  };

  function setNarrative(moduleKey) {
    const el = document.getElementById('progress-narrative');
    if (!el) return;
    const text = MODULE_NARRATIVE[moduleKey];
    if (!text) return;
    el.style.opacity = '0';
    setTimeout(() => { el.textContent = text; el.style.opacity = '1'; }, 200);
    const label = document.getElementById('current-module-label');
    if (label) label.textContent = text;
  }

  let completedModules = new Set();
  let pollTimer = null;

  function setProgress(pct) {
    const bar = document.getElementById('progress-bar');
    const label = document.getElementById('progress-pct');
    if (bar) bar.style.width = `${pct}%`;
    if (label) label.textContent = `${pct}%`;
  }

  function markModule(key, state) {
    const navEl = document.getElementById(`nav-${key}`);
    if (navEl) {
      navEl.classList.remove('running', 'done');
      if (state === 'done') navEl.classList.add('done');
      else if (state === 'running') navEl.classList.add('running');
    }
    if (state === 'done') {
      const count = document.querySelectorAll('.mod-nav-item.done').length;
      const countEl = document.getElementById('sidebar-count');
      if (countEl) countEl.textContent = count;
    }
    if (state === 'running') {
      document.querySelectorAll('.mod-nav-item.running').forEach(el => {
        if (el.id !== `nav-${key}`) el.classList.remove('running');
      });
    }
  }

  function showResults(data) {
    const reportUrl = `/en/audit/${auditId}/report`;
    const sidebarCta = document.getElementById('sidebar-cta');
    if (sidebarCta) sidebarCta.style.display = 'block';
    const reportLink = document.getElementById('sidebar-report-link');
    if (reportLink) reportLink.href = reportUrl;
    const procCard = document.getElementById('proc-card');
    const completeCard = document.getElementById('complete-card');
    if (procCard) procCard.style.display = 'none';
    if (completeCard) completeCard.style.display = 'block';
    const reportBtn = document.getElementById('report-btn');
    if (reportBtn) reportBtn.href = reportUrl;
    window.location.href = reportUrl;
  }

  function showError() {
    const procCard = document.getElementById('proc-card');
    const errorState = document.getElementById('error-state');
    if (procCard) procCard.style.display = 'none';
    if (errorState) errorState.style.display = 'block';
  }

  async function poll() {
    try {
      const res = await fetch(`/api/audit/${auditId}/status`);
      if (!res.ok) { showError(); return; }
      const data = await res.json();

      setProgress(data.progress || 0);

      if (data.module_completed) {
        completedModules.add(data.module_completed);
        MODULES.forEach((key, i) => {
          if (completedModules.has(key)) {
            markModule(key, 'done');
          } else if (i === completedModules.size) {
            markModule(key, 'running');
          }
        });
      }

      if (data.status === 'completed') {
        setProgress(100);
        MODULES.forEach(key => markModule(key, 'done'));
        showResults(data);
        return;
      }

      if (data.status === 'error') { showError(); return; }

      const nextIdx = completedModules.size;
      if (nextIdx < MODULES.length) {
        markModule(MODULES[nextIdx], 'running');
        setNarrative(MODULES[nextIdx]);
      }

      pollTimer = setTimeout(poll, 2000);
    } catch (err) {
      console.error('Poll error:', err);
      pollTimer = setTimeout(poll, 3000);
    }
  }

  if (initialStatus === 'completed') {
    poll();
  } else if (initialStatus === 'error') {
    showError();
  } else {
    markModule(MODULES[0], 'running');
    setNarrative(MODULES[0]);
    setProgress(2);
    setTimeout(poll, 1500);
  }
</script>
