---
import Layout from '../../layouts/Layout.astro';

const lang = 'en';
---

<Layout title="Free Digital Visibility Diagnostic — AION" description="Analyze your digital presence for free in 2 minutes. Get a full report with score, AI visibility and real growth opportunities." lang={lang}>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<style>
  :root {
    --surface: #f7f9ff;
    --surface-low: #edf4ff;
    --surface-high: #d8eaff;
    --primary: #000e41;
    --primary-cont: #001f70;
    --on-surface: #001d32;
    --on-surface-var: #43474d;
    --tertiary-fixed: #69ff87;
    --shadow: 0 12px 40px rgba(0,29,50,0.06);
  }
  *, *::before, *::after { box-sizing: border-box; }
  body { background: var(--surface) !important; color: var(--on-surface); font-family: 'Inter', system-ui, sans-serif; margin: 0; }
  .hidden { display: none !important; }

  .audit-shell {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 100vh;
    background: var(--surface);
  }
  .audit-sidebar {
    background: var(--surface-low);
    padding: 2rem 1.5rem;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  .audit-main {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 3.5rem 3rem;
    background: var(--surface);
  }
  .step-card {
    background: #fff;
    border-radius: 1rem;
    box-shadow: var(--shadow);
    padding: 2.5rem;
    width: 100%;
    max-width: 540px;
  }
  .step-nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    margin-bottom: 0.375rem;
    transition: background 0.2s;
    cursor: default;
  }
  .step-nav-item.active { background: var(--surface-high); }
  .step-nav-num {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
    background: rgba(195,198,206,0.3);
    color: var(--on-surface-var);
    transition: background 0.2s, color 0.2s;
  }
  .step-nav-item.active .step-nav-num {
    background: linear-gradient(135deg, var(--primary), var(--primary-cont));
    color: #fff;
  }
  .step-nav-item.done .step-nav-num { background: #e6ffd4; color: #1a6b00; }
  .field-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--on-surface);
    margin-bottom: 0.5rem;
  }
  .field-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--surface-low);
    border: none;
    outline: none;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    color: var(--on-surface);
    font-family: inherit;
    transition: background 0.15s, box-shadow 0.15s;
  }
  .field-input:focus { background: #fff; box-shadow: 0 0 0 2px rgba(0,14,65,0.4); }
  .field-input::placeholder { color: #9ca3af; }
  .btn-primary {
    display: block;
    width: 100%;
    padding: 0.875rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-cont) 100%);
    color: #fff;
    font-weight: 600;
    font-size: 0.9375rem;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.2s, transform 0.15s;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .btn-cta {
    display: block;
    width: 100%;
    padding: 0.875rem;
    background: var(--tertiary-fixed);
    color: #001905;
    font-weight: 700;
    font-size: 0.9375rem;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    font-family: inherit;
    transition: opacity 0.2s, transform 0.15s;
  }
  .btn-cta:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-cta:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .btn-ghost {
    display: block;
    width: 100%;
    padding: 0.875rem;
    background: transparent;
    color: var(--primary);
    font-weight: 500;
    font-size: 0.9375rem;
    border: 1px solid rgba(195,198,206,0.5);
    border-radius: 0.375rem;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s;
  }
  .btn-ghost:hover { background: var(--surface-low); }
  .competitor-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    border-radius: 0.5rem;
    background: var(--surface-low);
    cursor: pointer;
    transition: background 0.2s, box-shadow 0.2s;
    margin-bottom: 8px;
  }
  .competitor-card:hover { background: var(--surface-high); }
  .competitor-card.selected { background: var(--surface-high); box-shadow: 0 0 0 2px var(--primary); }
  .benefit-card {
    padding: 1rem 0.75rem;
    background: var(--surface-low);
    border-radius: 0.5rem;
    text-align: center;
  }
  .error-box {
    display: none;
    margin-top: 1rem;
    padding: 0.875rem 1rem;
    background: rgba(239,68,68,0.07);
    border-left: 3px solid #ef4444;
    border-radius: 0 0.375rem 0.375rem 0;
    font-size: 0.875rem;
    color: #b91c1c;
  }
  @media (max-width: 768px) {
    .audit-shell { grid-template-columns: 1fr; }
    .audit-sidebar { height: auto; position: relative; padding: 1rem 1.25rem 0.75rem; flex-direction: row; flex-wrap: wrap; align-items: center; gap: 0.75rem; }
    .sidebar-steps-nav { display: flex !important; flex-direction: row; gap: 0.375rem; }
    .sidebar-bottom-note { display: none; }
    .sidebar-brand { margin-bottom: 0 !important; }
    .audit-main { padding: 1.5rem 1.25rem; }
    .step-card { padding: 1.75rem 1.25rem; }
  }
</style>

  <div class="audit-shell">

    <!-- ═══ LEFT SIDEBAR ═══ -->
    <aside class="audit-sidebar">
      <div class="sidebar-brand" style="margin-bottom:2.5rem;">
        <a href="/en/" style="display:inline-block;margin-bottom:0.75rem;">
          <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:1.75rem;width:auto;" />
        </a>
        <p style="font-size:0.6875rem;font-weight:600;color:var(--on-surface-var);text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.125rem;">Digital Audit</p>
        <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;">Free analysis · 2 min</p>
      </div>

      <nav id="step-nav" class="sidebar-steps-nav" style="display:flex;flex-direction:column;">
        <div class="step-nav-item active" id="step-nav-1" data-n="1">
          <div class="step-nav-num" id="step-nav-num-1">1</div>
          <div>
            <p style="font-size:0.875rem;font-weight:600;color:var(--on-surface);margin:0 0 0.1rem;">Your website</p>
            <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;">The URL to analyze</p>
          </div>
        </div>
        <div class="step-nav-item" id="step-nav-2" data-n="2">
          <div class="step-nav-num" id="step-nav-num-2">2</div>
          <div>
            <p style="font-size:0.875rem;font-weight:600;color:var(--on-surface);margin:0 0 0.1rem;">Your details</p>
            <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;">Name and email</p>
          </div>
        </div>
        <div class="step-nav-item" id="step-nav-3" data-n="3">
          <div class="step-nav-num" id="step-nav-num-3">3</div>
          <div>
            <p style="font-size:0.875rem;font-weight:600;color:var(--on-surface);margin:0 0 0.1rem;">Competitors</p>
            <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;">Optional</p>
          </div>
        </div>
      </nav>

      <div class="sidebar-bottom-note" style="margin-top:auto;padding-top:2rem;">
        <p style="font-size:0.75rem;color:var(--on-surface-var);line-height:1.6;margin:0 0 1rem;">
          No credit card.<br/>No spam.
        </p>
        <div style="display:flex;gap:0.5rem;align-items:center;">
          <a href="/es/diagnostico" style="font-size:0.75rem;color:var(--on-surface-var);text-decoration:none;">ES</a>
          <span style="color:var(--on-surface-var);font-size:0.75rem;">|</span>
          <a href="/en/diagnostic" style="font-size:0.75rem;font-weight:700;color:var(--primary);text-decoration:none;">EN</a>
        </div>
      </div>
    </aside>

    <!-- ═══ MAIN CONTENT ═══ -->
    <main class="audit-main">

      <!-- STEP 1: URL -->
      <div id="step-1" class="step-card">
        <div style="margin-bottom:1.75rem;">
          <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.35rem 0.875rem;background:var(--surface-high);border-radius:9999px;font-size:0.6875rem;font-weight:600;color:var(--primary);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">
            <span style="width:6px;height:6px;border-radius:50%;background:var(--primary);display:inline-block;flex-shrink:0;"></span>
            Free · No signup · 2 minutes
          </div>
          <h1 style="font-size:1.625rem;font-weight:800;color:var(--primary);margin:0 0 0.75rem;line-height:1.2;">Analyze your digital visibility</h1>
          <p style="font-size:0.9rem;color:var(--on-surface-var);line-height:1.65;margin:0;">Get a full report with score, web performance, AI visibility and growth opportunities.</p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:1.75rem;">
          <div class="benefit-card">
            <svg width="22" height="22" fill="none" stroke="var(--primary)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" style="margin:0 auto 0.5rem;display:block;"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;font-weight:500;">Digital Score</p>
          </div>
          <div class="benefit-card">
            <svg width="22" height="22" fill="none" stroke="var(--primary)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" style="margin:0 auto 0.5rem;display:block;"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;font-weight:500;">AI Visibility</p>
          </div>
          <div class="benefit-card">
            <svg width="22" height="22" fill="none" stroke="var(--primary)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" style="margin:0 auto 0.5rem;display:block;"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;font-weight:500;">Web Performance</p>
          </div>
          <div class="benefit-card">
            <svg width="22" height="22" fill="none" stroke="var(--primary)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" style="margin:0 auto 0.5rem;display:block;"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;font-weight:500;">Opportunities</p>
          </div>
        </div>

        <div style="margin-bottom:1.25rem;">
          <label for="url" class="field-label">Your website *</label>
          <div style="position:relative;">
            <input type="text" id="url" name="url" required placeholder="example.com"
              class="field-input"
              inputmode="url" autocomplete="url" />
            <span id="url-status" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);font-size:0.875rem;font-weight:600;"></span>
          </div>
          <p id="url-feedback" style="font-size:0.75rem;margin-top:0.375rem;display:none;"></p>
        </div>

        <button id="btn-step1" type="button" class="btn-cta" aria-label="Analyze my website">
          Analyze my website →
        </button>

        <div id="error-step1" class="error-box" role="alert"></div>

        <p style="text-align:center;font-size:0.75rem;color:var(--on-surface-var);margin-top:1.25rem;">
          By continuing you accept our <a href="/en/" style="color:var(--primary);text-decoration:underline;">privacy policy</a>
        </p>
      </div>

      <!-- STEP 2: Name + Email -->
      <div id="step-2" class="step-card hidden">
        <div style="margin-bottom:1.75rem;">
          <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.35rem 0.875rem;background:#e6ffd4;border-radius:9999px;font-size:0.6875rem;font-weight:600;color:#1a6b00;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">
            <svg width="12" height="12" fill="#1a6b00" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            Your site is being analyzed
          </div>
          <h2 style="font-size:1.5rem;font-weight:800;color:var(--primary);margin:0 0 0.75rem;">Receive results by email</h2>
          <p style="font-size:0.9rem;color:var(--on-surface-var);line-height:1.65;margin:0;">We'll send you a detailed report with personalized recommendations. What's your name?</p>
        </div>

        <div style="margin-bottom:1.25rem;">
          <label for="name" class="field-label">Your name *</label>
          <input type="text" id="name" name="name" required placeholder="John Smith"
            class="field-input" autocomplete="name" />
        </div>
        <div style="margin-bottom:1.5rem;">
          <label for="email" class="field-label">Your email *</label>
          <input type="email" id="email" name="email" required placeholder="john@company.com"
            class="field-input" autocomplete="email" />
          <p id="email-feedback" style="font-size:0.75rem;margin-top:0.375rem;display:none;"></p>
        </div>

        <button id="btn-step2" type="button" class="btn-primary" aria-label="Continue">
          Continue →
        </button>

        <div id="error-step2" class="error-box" role="alert"></div>

        <p style="text-align:center;font-size:0.75rem;color:var(--on-surface-var);margin-top:1.25rem;">
          By continuing you accept our <a href="/en/" style="color:var(--primary);text-decoration:underline;">privacy policy</a>
        </p>
      </div>

      <!-- STEP 3: Competitors -->
      <div id="step-3" class="step-card hidden">
        <div style="margin-bottom:1.5rem;">
          <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.35rem 0.875rem;background:#e6ffd4;border-radius:9999px;font-size:0.6875rem;font-weight:600;color:#1a6b00;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:1rem;">
            <svg width="12" height="12" fill="#1a6b00" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            Details saved
          </div>
          <h2 style="font-size:1.5rem;font-weight:800;color:var(--primary);margin:0 0 0.75rem;">Who do you compete with?</h2>
          <p style="font-size:0.9rem;color:var(--on-surface-var);line-height:1.65;margin:0;">Add 1-3 competitors to see how you compare in visibility, rankings and digital strategy. (Optional)</p>
        </div>

        <div id="competitor-list" style="margin-bottom:1.25rem;"></div>

        <div style="margin-bottom:1.25rem;padding:1.25rem;background:var(--surface-low);border-radius:0.625rem;">
          <label class="field-label">Add competitors manually</label>
          <div style="display:flex;gap:0.5rem;margin-bottom:0.75rem;">
            <input type="text" id="manual-competitor-input" placeholder="competitor.com"
              class="field-input" style="flex:1;"
              inputmode="url" />
            <button id="btn-add-competitor" type="button"
              style="padding:0.75rem 1rem;background:var(--primary);color:#fff;font-size:0.875rem;font-weight:600;border:none;border-radius:0.375rem;cursor:pointer;font-family:inherit;white-space:nowrap;"
              aria-label="Add competitor">
              + Add
            </button>
          </div>
          <div id="manual-competitors-list" style="display:flex;flex-wrap:wrap;gap:0.5rem;"></div>
        </div>

        <div style="display:flex;flex-direction:column;gap:0.75rem;">
          <button id="btn-start-audit" type="button" class="btn-cta" aria-label="Start analysis">
            Start analysis →
          </button>
          <button id="btn-skip-step3" type="button" class="btn-ghost" aria-label="Skip comparison">
            Skip for now
          </button>
        </div>

        <div id="error-step3" class="error-box" role="alert"></div>
      </div>

    </main>
  </div>

</Layout>

<script>
  let userData: { url: string; name: string; email: string } = { url: '', name: '', email: '' };
  let competitorsPromise: Promise<any> | null = null;
  let competitorsResult: any = null;
  let selectedCompetitors: string[] = [];
  let manualCompetitors: string[] = [];

  function renderManualCompetitors() {
    const list = document.getElementById('manual-competitors-list');
    if (!list) return;
    list.innerHTML = manualCompetitors.map(url => `
      <div style="display:flex;align-items:center;gap:0.375rem;padding:0.375rem 0.75rem;background:#fff;border:1px solid rgba(195,198,206,0.4);border-radius:0.375rem;">
        <span style="font-size:0.75rem;color:#001d32;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${url}</span>
        <button onclick="removeManualCompetitor('${url}')" style="color:#9ca3af;background:none;border:none;cursor:pointer;font-size:1rem;line-height:1;margin-left:0.125rem;padding:0;">×</button>
      </div>
    `).join('');
  }

  (window as any).removeManualCompetitor = function(url: string) {
    manualCompetitors = manualCompetitors.filter(u => u !== url);
    renderManualCompetitors();
  };

  function addManualCompetitor() {
    const input = document.getElementById('manual-competitor-input') as HTMLInputElement;
    const val = input.value.trim().replace(/^https?:\/\//, '').replace(/\/$/, '');
    if (!val || manualCompetitors.includes(val)) { input.value = ''; return; }
    manualCompetitors.push(val);
    renderManualCompetitors();
    input.value = '';
  }

  document.getElementById('btn-add-competitor')?.addEventListener('click', addManualCompetitor);
  document.getElementById('manual-competitor-input')?.addEventListener('keydown', (e: any) => {
    if (e.key === 'Enter') { e.preventDefault(); addManualCompetitor(); }
  });

  function updateStepNav(current: number) {
    [1, 2, 3].forEach(n => {
      const item = document.getElementById(`step-nav-${n}`);
      const num = document.getElementById(`step-nav-num-${n}`);
      if (!item || !num) return;
      item.classList.remove('active', 'done');
      if (n === current) { item.classList.add('active'); num.textContent = String(n); }
      else if (n < current) { item.classList.add('done'); num.textContent = '✓'; }
      else { num.textContent = String(n); }
    });
  }

  function showStep(n: number) {
    updateStepNav(n);
    [1, 2, 3].forEach(i => {
      const el = document.getElementById(`step-${i}`);
      if (el) el.classList.toggle('hidden', i !== n);
    });
  }

  function showError(id: string, msg: string) {
    const el = document.getElementById(id) as HTMLElement;
    if (el) { el.textContent = msg; el.style.display = 'block'; }
  }

  function hideError(id: string) {
    const el = document.getElementById(id) as HTMLElement;
    if (el) el.style.display = 'none';
  }

  function setBtn(id: string, text: string, disabled: boolean) {
    const btn = document.getElementById(id) as HTMLButtonElement;
    if (btn) { btn.textContent = text; btn.disabled = disabled; }
  }

  const urlInput = document.getElementById('url') as HTMLInputElement;
  if (urlInput) {
    urlInput.addEventListener('input', () => {
      const value = urlInput.value.trim();
      const feedback = document.getElementById('url-feedback') as HTMLElement;
      const status = document.getElementById('url-status') as HTMLElement;
      if (value.length > 0) {
        const isValid = /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(value.replace(/^https?:\/\//, '').replace(/\/$/, ''));
        if (isValid) {
          if (feedback) { feedback.textContent = '✓ Valid URL'; feedback.style.color = '#16a34a'; feedback.style.display = 'block'; }
          if (status) { status.textContent = '✓'; status.style.color = '#16a34a'; }
        } else {
          if (feedback) { feedback.textContent = 'Incorrect format (e.g. example.com)'; feedback.style.color = '#dc2626'; feedback.style.display = 'block'; }
          if (status) { status.textContent = '✗'; status.style.color = '#dc2626'; }
        }
      } else {
        if (feedback) feedback.style.display = 'none';
        if (status) status.textContent = '';
      }
    });
  }

  document.getElementById('btn-step1')?.addEventListener('click', async () => {
    hideError('error-step1');
    const url = (document.getElementById('url') as HTMLInputElement).value.trim();
    if (!url) return showError('error-step1', 'Please enter your website URL.');
    const isValid = /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(url.replace(/^https?:\/\//, '').replace(/\/$/, ''));
    if (!isValid) return showError('error-step1', 'Please enter a valid URL (e.g. example.com).');
    userData = { ...userData, url };
    showStep(2);
  });

  document.getElementById('btn-step2')?.addEventListener('click', async () => {
    hideError('error-step2');
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    if (!name) return showError('error-step2', 'Please enter your name.');
    if (!email || !email.includes('@')) return showError('error-step2', 'Please enter a valid email.');
    userData = { ...userData, name, email };
    setBtn('btn-step2', 'Looking for competitors…', true);

    const listEl = document.getElementById('competitor-list');
    if (listEl) {
      listEl.innerHTML = `
        <div style="padding:1rem 0;">
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            <div id="step-analyze" style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem;border-radius:0.5rem;background:var(--surface-low);">
              <div style="width:18px;height:18px;border-radius:50%;border:2px solid var(--primary);display:flex;align-items:center;justify-content:center;">
                <div style="width:6px;height:6px;border-radius:50%;background:var(--primary);animation:pulse-dot 1s infinite;"></div>
              </div>
              <span style="font-size:0.875rem;color:var(--on-surface);">Analyzing your site...</span>
            </div>
            <div id="step-sector" style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem;border-radius:0.5rem;background:var(--surface-low);opacity:0.4;">
              <div style="width:18px;height:18px;border-radius:50%;border:2px solid rgba(195,198,206,0.5);"></div>
              <span style="font-size:0.875rem;color:var(--on-surface-var);">Identifying your sector</span>
            </div>
            <div id="step-competitors-anim" style="display:flex;align-items:center;gap:0.75rem;padding:0.75rem;border-radius:0.5rem;background:var(--surface-low);opacity:0.4;">
              <div style="width:18px;height:18px;border-radius:50%;border:2px solid rgba(195,198,206,0.5);"></div>
              <span style="font-size:0.875rem;color:var(--on-surface-var);">Searching for competitors</span>
            </div>
          </div>
        </div>
      `;
      setTimeout(() => {
        const s1 = document.getElementById('step-analyze');
        const s2 = document.getElementById('step-sector');
        if (s1) s1.innerHTML = '<div style="width:18px;height:18px;border-radius:50%;background:#e6ffd4;display:flex;align-items:center;justify-content:center;"><svg width="10" height="10" fill="#1a6b00" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg></div><span style="font-size:0.875rem;color:#1a6b00;font-weight:500;">Site analyzed</span>';
        if (s2) { s2.style.opacity = '1'; s2.innerHTML = '<div style="width:18px;height:18px;border-radius:50%;border:2px solid var(--primary);display:flex;align-items:center;justify-content:center;"><div style="width:6px;height:6px;border-radius:50%;background:var(--primary);animation:pulse-dot 1s infinite;"></div></div><span style="font-size:0.875rem;color:var(--on-surface);">Identifying your sector...</span>'; }
      }, 1200);
      setTimeout(() => {
        const s2 = document.getElementById('step-sector');
        const s3 = document.getElementById('step-competitors-anim');
        if (s2) s2.innerHTML = '<div style="width:18px;height:18px;border-radius:50%;background:#e6ffd4;display:flex;align-items:center;justify-content:center;"><svg width="10" height="10" fill="#1a6b00" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg></div><span style="font-size:0.875rem;color:#1a6b00;font-weight:500;">Sector identified</span>';
        if (s3) { s3.style.opacity = '1'; s3.innerHTML = '<div style="width:18px;height:18px;border-radius:50%;border:2px solid var(--primary);display:flex;align-items:center;justify-content:center;"><div style="width:6px;height:6px;border-radius:50%;background:var(--primary);animation:pulse-dot 1s infinite;"></div></div><span style="font-size:0.875rem;color:var(--on-surface);">Searching for competitors...</span>'; }
      }, 2400);
    }

    competitorsResult = null;
    competitorsPromise = fetch('/api/audit/find-competitors', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url: userData.url }),
    })
      .then(r => r.json())
      .then(data => { competitorsResult = data; renderStep3(); return data; })
      .catch(() => { competitorsResult = { competitors: [] }; renderStep3(); });

    showStep(3);
  });

  function renderStep3() {
    const competitors = competitorsResult?.competitors || [];
    const listEl = document.getElementById('competitor-list');
    selectedCompetitors = [];
    if (listEl) {
      if (competitors.length === 0) {
        listEl.innerHTML = `<p style="font-size:0.8125rem;color:var(--on-surface-var);text-align:center;padding:1rem 0;">No competitors detected automatically. You can add one manually below.</p>`;
      } else {
        listEl.innerHTML = competitors.map((c: any, i: number) => `
          <div class="competitor-card" data-url="${c.url}" data-idx="${i}" onclick="toggleCompetitor(this)">
            <div style="width:18px;height:18px;border-radius:4px;border:2px solid rgba(195,198,206,0.5);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.2s;" class="check-icon">
              <svg class="check-mark" width="10" height="10" fill="var(--primary)" viewBox="0 0 20 20" style="display:none;">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div style="flex:1;min-width:0;">
              <p style="font-size:0.875rem;font-weight:600;color:var(--on-surface);margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${c.name}</p>
              <p style="font-size:0.75rem;color:var(--on-surface-var);margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${c.url}</p>
            </div>
          </div>
        `).join('');
      }
    }
  }

  (window as any).toggleCompetitor = function(el: HTMLElement) {
    const url = el.getAttribute('data-url') || '';
    const isSelected = el.classList.contains('selected');
    const checkIcon = el.querySelector('.check-icon') as HTMLElement;
    const checkMark = el.querySelector('.check-mark') as HTMLElement;
    if (isSelected) {
      el.classList.remove('selected');
      if (checkIcon) { checkIcon.style.background = ''; checkIcon.style.borderColor = 'rgba(195,198,206,0.5)'; }
      if (checkMark) checkMark.style.display = 'none';
      selectedCompetitors = selectedCompetitors.filter(u => u !== url);
    } else {
      el.classList.add('selected');
      if (checkIcon) { checkIcon.style.background = 'var(--surface-high)'; checkIcon.style.borderColor = 'var(--primary)'; }
      if (checkMark) checkMark.style.display = 'block';
      if (!selectedCompetitors.includes(url)) selectedCompetitors.push(url);
    }
  };

  async function startAudit(withCompetitors: boolean) {
    hideError('error-step3');
    setBtn('btn-start-audit', 'Starting…', true);
    setBtn('btn-skip-step3', '…', true);
    const allCompetitors = withCompetitors ? [...selectedCompetitors, ...manualCompetitors] : [];
    try {
      const res = await fetch('/api/audit/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url: userData.url, email: userData.email, name: userData.name, selectedCompetitors: allCompetitors }),
      });
      const result = await res.json();
      if (res.ok && result.audit_id) {
        window.location.href = `/en/audit/${result.audit_id}`;
      } else {
        showError('error-step3', result.error || 'An error occurred. Please try again.');
        setBtn('btn-start-audit', 'Start analysis →', false);
        setBtn('btn-skip-step3', 'Skip for now', false);
      }
    } catch {
      showError('error-step3', 'Connection error. Please try again.');
      setBtn('btn-start-audit', 'Start analysis →', false);
      setBtn('btn-skip-step3', 'Skip for now', false);
    }
  }

  document.getElementById('btn-start-audit')?.addEventListener('click', () => startAudit(true));
  document.getElementById('btn-skip-step3')?.addEventListener('click', () => startAudit(false));
</script>
