---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'es' | 'en';
}

const {
  title,
  description = 'AION Growth Studio — Infraestructura de crecimiento con IA agentiva',
  lang = 'es',
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <title>{title}</title>
  </head>
  <body class="font-sans antialiased text-slate-900 bg-white">
    <slot />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  h1, h2, h3 {
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  h4, h5 {
    font-weight: 600;
  }

  p {
    font-weight: 400;
    line-height: 1.6;
  }

  .fade-in {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1), transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger animation delays for children */
  .fade-in-stagger > *:nth-child(1) { transition-delay: 0ms; }
  .fade-in-stagger > *:nth-child(2) { transition-delay: 75ms; }
  .fade-in-stagger > *:nth-child(3) { transition-delay: 150ms; }
  .fade-in-stagger > *:nth-child(4) { transition-delay: 225ms; }
  .fade-in-stagger > *:nth-child(5) { transition-delay: 300ms; }
  .fade-in-stagger > *:nth-child(6) { transition-delay: 375ms; }
</style>
