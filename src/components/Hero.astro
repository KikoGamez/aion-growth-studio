---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import Header from './Header.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
---

<section class="relative w-full overflow-hidden" style="min-height: 100svh; background: #000e41;">
  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 z-0" style="
    background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  "></div>

  <!-- Radial glow — right side accent -->
  <div class="absolute z-0" style="
    top: -10%;
    right: -5%;
    width: 55%;
    height: 80%;
    background: radial-gradient(ellipse at top right, rgba(0, 165, 181, 0.18) 0%, rgba(0, 102, 204, 0.12) 40%, transparent 70%);
    pointer-events: none;
  "></div>

  <!-- Bottom accent -->
  <div class="absolute z-0 bottom-0 left-0 right-0" style="
    height: 35%;
    background: linear-gradient(to top, rgba(0,14,65,0.8) 0%, transparent 100%);
    pointer-events: none;
  "></div>

  <!-- Header sits inside hero (transparent) -->
  <Header lang={lang} />

  <!-- Main hero content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 flex flex-col justify-center" style="min-height: calc(100svh - 72px); padding-top: 4rem; padding-bottom: 5rem;">

    <div class="max-w-4xl">
      <!-- Tagline pill -->
      <div class="inline-flex items-center gap-2 mb-6 md:mb-8">
        <span class="w-5 h-px" style="background: #4cd964;"></span>
        <span class="text-xs font-semibold tracking-widest uppercase" style="color: #4cd964;">{t('hero.tagline')}</span>
      </div>

      <!-- Main headline -->
      <h1 class="font-bold text-white text-balance mb-6" style="
        font-size: clamp(2.4rem, 6vw, 4.5rem);
        line-height: 1.1;
        letter-spacing: -0.03em;
      ">
        {t('hero.title.1')}<br />
        <span style="color: #00a5b5;">{t('hero.title.2')}</span>
      </h1>

      <!-- Subtitle -->
      <p class="mb-10 md:mb-12 max-w-xl" style="
        font-size: clamp(1rem, 2vw, 1.2rem);
        line-height: 1.6;
        color: rgba(255,255,255,0.62);
        font-weight: 400;
      ">
        {t('hero.subtitle')}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center gap-4">
        <a
          href={lang === 'es' ? '/es/diagnostico' : '/en/diagnostic'}
          class="inline-flex items-center gap-2 px-6 py-3.5 rounded-md font-semibold text-[#000e41] text-sm transition-all duration-200 hover:scale-[1.03]"
          style="background: #4cd964;"
        >
          {t('hero.cta')}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>

        <a
          href={`${basePath}/#soluciones`}
          class="inline-flex items-center gap-2 px-6 py-3.5 rounded-md font-semibold text-sm transition-all duration-200"
          style="color: rgba(255,255,255,0.75); border: 1px solid rgba(255,255,255,0.2);"
          onmouseover="this.style.borderColor='rgba(255,255,255,0.5)'; this.style.color='white';"
          onmouseout="this.style.borderColor='rgba(255,255,255,0.2)'; this.style.color='rgba(255,255,255,0.75)';"
        >
          Ver soluciones
        </a>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap items-center gap-6 mt-12 pt-10" style="border-top: 1px solid rgba(255,255,255,0.1);">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" style="color:#4cd964;" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-xs font-medium" style="color:rgba(255,255,255,0.55);">Deploy en 8 semanas</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" style="color:#4cd964;" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-xs font-medium" style="color:rgba(255,255,255,0.55);">Desde €12K</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" style="color:#4cd964;" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-xs font-medium" style="color:rgba(255,255,255,0.55);">4.9/5 rating clientes</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" style="color:#4cd964;" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          <span class="text-xs font-medium" style="color:rgba(255,255,255,0.55);">Diagnóstico gratuito incluido</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 hidden md:flex flex-col items-center gap-1.5" style="color: rgba(255,255,255,0.3);">
    <span class="text-[10px] font-medium tracking-widest uppercase">Scroll</span>
    <div class="w-px h-8 animate-pulse" style="background: linear-gradient(to bottom, rgba(255,255,255,0.3), transparent);"></div>
  </div>
</section>
