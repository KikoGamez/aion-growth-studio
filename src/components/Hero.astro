---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
---

<section class="relative min-h-screen w-full overflow-hidden bg-gradient-primary">
  <!-- Subtle gradient overlay for depth -->
  <div class="absolute inset-0 z-[1] bg-gradient-to-b from-transparent via-transparent to-primary/20"></div>

  <!-- Navigation -->
  <nav class="relative z-50 flex items-center justify-between px-6 md:px-8 lg:px-16 py-6">
    <!-- Logo -->
    <a href={`${basePath}/`} class="flex items-center">
      <img
        src="/logo-aion-outline.png"
        alt="AION Growth Studio"
        class="h-12 md:h-14 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop nav pills - glassmorphism -->
    <div class="hidden lg:flex items-center gap-1.5">
      <a href={`${basePath}/#soluciones`} class="nav-pill">{t('nav.soluciones')}</a>
      <a href={`${basePath}/#casos`} class="nav-pill">{t('nav.casos')}</a>
      <a href={lang === 'es' ? '/es/diagnostico' : '/en/diagnostic'} class="nav-pill">{t('nav.diagnostico')}</a>
      <a href={`/${lang === 'es' ? '' : 'en/'}blog`} class="nav-pill">{t('nav.blog')}</a>
      <a href={`${basePath}/#contacto`} class="nav-pill">{t('nav.contacto')}</a>

      <div class="flex items-center gap-1.5 ml-4 px-4 py-2.5 rounded-full nav-glass">
        <a href="/es/" class={`text-sm font-medium transition-colors ${lang === 'es' ? 'text-white' : 'text-white/50 hover:text-white'}`}>ES</a>
        <span class="text-white/30 text-sm">|</span>
        <a href="/en/" class={`text-sm font-medium transition-colors ${lang === 'en' ? 'text-white' : 'text-white/50 hover:text-white'}`}>EN</a>
      </div>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="lg:hidden p-2 -mr-2" aria-label="Menu" aria-expanded="false">
      <svg id="menu-open" class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-close" class="w-7 h-7 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu - glassmorphism -->
  <div id="mobile-menu" class="lg:hidden hidden absolute top-[80px] left-4 right-4 z-50 nav-glass-mobile rounded-2xl">
    <div class="px-6 py-6 flex flex-col gap-1">
      <a href={`${basePath}/#soluciones`} class="mobile-pill">{t('nav.soluciones')}</a>
      <a href={`${basePath}/#casos`} class="mobile-pill">{t('nav.casos')}</a>
      <a href={lang === 'es' ? '/es/diagnostico' : '/en/diagnostic'} class="mobile-pill">{t('nav.diagnostico')}</a>
      <a href={`/${lang === 'es' ? '' : 'en/'}blog`} class="mobile-pill">{t('nav.blog')}</a>
      <a href={`${basePath}/#contacto`} class="mobile-pill">{t('nav.contacto')}</a>
      <div class="flex items-center gap-3 mt-4 pt-4 border-t border-white/10">
        <a href="/es/" class={`text-sm font-medium ${lang === 'es' ? 'text-white' : 'text-white/50'}`}>ES</a>
        <span class="text-white/20">|</span>
        <a href="/en/" class={`text-sm font-medium ${lang === 'en' ? 'text-white' : 'text-white/50'}`}>EN</a>
      </div>
    </div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 px-6 md:px-8 lg:px-16 pt-[16vh] md:pt-[20vh] pb-20">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Text LEFT -->
        <div class="max-w-xl">
          <!-- Label -->
          <p class="text-tertiary-fixed text-xs font-semibold uppercase tracking-label mb-4">
            Growth Infrastructure
          </p>

          <h1 class="hero-headline text-white mb-6">
            {t('hero.title.1')}<br />
            <span class="text-white/80">{t('hero.title.2')}</span>
          </h1>

          <p class="text-white/60 text-lg leading-relaxed mb-10 max-w-lg">
            {t('hero.subtitle')}
          </p>

          <!-- CTA with gradient -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={lang === 'es' ? '/es/diagnostico' : '/en/diagnostic'}
              class="cta-primary"
            >
              {t('hero.cta')}
              <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href={`${basePath}/#casos`}
              class="cta-secondary"
            >
              {t('nav.casos')}
            </a>
          </div>
        </div>

        <!-- Card RIGHT - ambient shadow, no borders -->
        <div class="hidden lg:block">
          <div class="relative">
            <!-- Main card -->
            <div class="bg-white rounded-2xl p-8 shadow-ambient">
              <div class="flex items-start gap-4 mb-6">
                <div class="w-12 h-12 rounded-xl bg-surface flex items-center justify-center">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                  </svg>
                </div>
                <div>
                  <p class="text-on-surface-variant text-xs font-medium uppercase tracking-label">{t('hero.card.label')}</p>
                  <h3 class="text-on-surface text-xl font-semibold tracking-editorial mt-1">
                    {t('hero.card.project')}
                  </h3>
                </div>
              </div>
              
              <p class="text-on-surface-variant text-sm leading-relaxed mb-6">
                {t('hero.card.title')}
              </p>

              <!-- Stats row -->
              <div class="grid grid-cols-3 gap-4 pt-6 border-t border-outline-variant/20">
                <div>
                  <p class="text-2xl font-bold text-on-surface tracking-editorial">+340%</p>
                  <p class="text-xs text-on-surface-variant mt-0.5">Organic Traffic</p>
                </div>
                <div>
                  <p class="text-2xl font-bold text-on-surface tracking-editorial">12x</p>
                  <p class="text-xs text-on-surface-variant mt-0.5">Lead Quality</p>
                </div>
                <div>
                  <p class="text-2xl font-bold text-tertiary-fixed tracking-editorial">8 sem</p>
                  <p class="text-xs text-on-surface-variant mt-0.5">Time to Results</p>
                </div>
              </div>
            </div>

            <!-- Floating decorative element -->
            <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-tertiary-fixed/10 rounded-full blur-3xl"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom accent line -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent"></div>
</section>

<style>
  .bg-gradient-primary {
    background: linear-gradient(135deg, #000e41 0%, #001f70 100%);
  }

  .hero-headline {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .tracking-editorial {
    letter-spacing: -0.02em;
  }

  .tracking-label {
    letter-spacing: 0.08em;
  }

  /* Nav pills - glassmorphism */
  .nav-pill {
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .nav-pill:hover {
    background: rgba(255, 255, 255, 0.15);
    color: white;
  }

  .nav-glass {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .nav-glass-mobile {
    background: rgba(0, 14, 65, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .mobile-pill {
    display: block;
    padding: 0.875rem 1rem;
    border-radius: 0.75rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .mobile-pill:hover {
    background: rgba(255, 255, 255, 0.08);
    color: white;
  }

  /* CTAs */
  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    background: white;
    color: #000e41;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
    box-shadow: 0 12px 40px rgba(0, 29, 50, 0.15);
  }

  .cta-primary:hover {
    background: #69ff87;
    transform: translateY(-2px);
    box-shadow: 0 16px 48px rgba(0, 29, 50, 0.2);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    background: transparent;
    color: white;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 0.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: all 0.2s ease;
  }

  .cta-secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.3);
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpen = document.getElementById('menu-open');
  const menuClose = document.getElementById('menu-close');

  if (menuBtn && mobileMenu && menuOpen && menuClose) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      menuOpen.classList.toggle('hidden');
      menuClose.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuOpen.classList.remove('hidden');
        menuClose.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
