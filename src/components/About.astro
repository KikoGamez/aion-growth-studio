---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const headlineWords = t('about.headline').split(' ');
---

<section class="py-20 md:py-28 bg-white w-full">
  <div class="section-container">

    <p class="section-eyebrow fade-in flex items-center gap-2.5">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
      </svg>
      {t('about.label')}
    </p>

    <!-- Right-aligned text with per-word hover effect -->
    <div class="max-w-4xl ml-auto text-right mb-10 md:mb-14 fade-in">
      <h2 class="text-display-md md:text-display-lg lg:text-display-xl about-headline text-aion-dark">
        {headlineWords.map((word: string) => (
          <span class="inline-block hover-word mr-[0.2em]">
            {word}
          </span>
        ))}
      </h2>
    </div>

    <!-- CTA link -->
    <div class="text-right max-w-4xl ml-auto mb-14 md:mb-18 fade-in">
      <a href="#contacto" class="group inline-flex items-center gap-2.5 text-aion-dark font-semibold text-lg hover:text-aion-accent transition-colors">
        {t('about.cta')}
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Stats cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 fade-in">
      <!-- Rating card -->
      <div class="p-7 rounded-2xl bg-surface-secondary border border-slate-100 card-hover">
        <div class="flex items-center gap-0.5 mb-3">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-aion-muted text-sm">{t('about.rating')}</p>
      </div>

      <!-- Revenue card -->
      <div class="p-7 rounded-2xl bg-surface-secondary border border-slate-100 card-hover">
        <p class="text-3xl font-bold text-aion-dark mb-1.5 tracking-tight">{t('about.stat.1.value')}</p>
        <p class="text-aion-muted text-sm">{t('about.stat.1.label')}</p>
      </div>

      <!-- Deployment card -->
      <div class="p-7 rounded-2xl bg-surface-secondary border border-slate-100 card-hover">
        <p class="text-3xl font-bold text-aion-dark mb-1.5 tracking-tight">{t('about.stat.2.value')}</p>
        <p class="text-aion-muted text-sm">{t('about.stat.2.label')}</p>
      </div>
    </div>

  </div>
</section>

<style>
  .hover-word {
    transition: color 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: default;
  }

  .hover-word:hover {
    color: rgb(14 165 233);
  }
</style>
