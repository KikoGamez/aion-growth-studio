---
export interface Props {
  values: number[];
  width?: number;
  height?: number;
  color?: string;
}

const { values, width = 120, height = 40, color = '#00346d' } = Astro.props;

// Build SVG polyline path
function buildSparkline(vals: number[], w: number, h: number): string {
  if (vals.length < 2) return '';
  const min = Math.min(...vals);
  const max = Math.max(...vals);
  const range = max - min || 1;
  const step = w / (vals.length - 1);
  return vals
    .map((v, i) => {
      const x = i * step;
      const y = h - ((v - min) / range) * h;
      return `${x},${y}`;
    })
    .join(' ');
}

const points = buildSparkline(values, width, height);
---

<svg width={width} height={height} viewBox={`0 0 ${width} ${height}`} fill="none" xmlns="http://www.w3.org/2000/svg">
  {points && (
    <polyline
      points={points}
      stroke={color}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"
    />
  )}
  {points && values.length > 0 && (() => {
    const min = Math.min(...values);
    const max = Math.max(...values);
    const range = max - min || 1;
    const step = width / (values.length - 1);
    const lastX = (values.length - 1) * step;
    const lastY = height - ((values[values.length - 1] - min) / range) * height;
    return <circle cx={lastX} cy={lastY} r="3" fill={color} />;
  })()}
</svg>
