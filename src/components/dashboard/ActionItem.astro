---
export interface Props {
  title: string;
  status: 'done' | 'in_progress' | 'pending';
  impact?: 'high' | 'medium' | 'low';
  recommendationId?: string;
  description?: string;
}

const { title, status, impact = 'medium', recommendationId, description } = Astro.props;

const impactBg = impact === 'high' ? '#d6e3ff' : impact === 'low' ? '#f0f0f0' : '#e8e5ff';
const impactColor = impact === 'high' ? '#124687' : impact === 'low' ? '#888' : '#434750';
const impactLabel = impact === 'high' ? 'Impacto Alto' : impact === 'medium' ? 'Impacto Medio' : 'Impacto Bajo';
const isTrackable = !!recommendationId;
---

<div
  class="action-item"
  data-rec-id={recommendationId || ''}
  data-status={status}
  style={`display:flex;align-items:flex-start;gap:16px;padding:12px 16px;border-radius:10px;transition:background 0.15s;${status === 'in_progress' ? 'background:#f5f2ff;box-shadow:0 0 0 1px rgba(0,52,109,0.08);' : ''}${isTrackable ? 'cursor:pointer;' : ''}`}
>
  <!-- Status icon (clickable if trackable) -->
  <div class="action-toggle" style="flex-shrink:0;margin-top:2px;">
    {status === 'done' && (
      <span class="material-symbols-outlined filled-icon" style="color:#1d9e75;font-size:20px;">check_circle</span>
    )}
    {status === 'in_progress' && (
      <div style="width:20px;height:20px;border-radius:50%;border:2px solid #ba7517;display:flex;align-items:center;justify-content:center;">
        <div style="width:8px;height:8px;border-radius:50%;background:#ba7517;"></div>
      </div>
    )}
    {status === 'pending' && (
      <span class="material-symbols-outlined" style="color:#c3c6d2;font-size:20px;">radio_button_unchecked</span>
    )}
  </div>

  <!-- Content -->
  <div style="flex:1;min-width:0;">
    <span style={`font-size:14px;font-weight:${status === 'in_progress' ? '700' : '500'};color:${status === 'done' ? '#434750' : '#1a1a2e'};${status === 'done' ? 'text-decoration:line-through;opacity:0.5;' : ''}`}>
      {title}
    </span>
    {description && (
      <p style={`font-size:12px;color:#888;margin:4px 0 0;line-height:1.4;${status === 'done' ? 'opacity:0.5;' : ''}`}>{description}</p>
    )}
  </div>

  <!-- Impact badge -->
  <span style={`padding:2px 8px;border-radius:999px;background:${impactBg};color:${impactColor};font-size:10px;font-weight:700;white-space:nowrap;flex-shrink:0;margin-top:2px;`}>
    {impactLabel}
  </span>
</div>

<style>
  .action-item:hover {
    background: #f9f8ff;
  }
</style>
