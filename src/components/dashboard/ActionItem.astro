---
export interface Props {
  title: string;
  status: 'done' | 'in_progress' | 'pending';
  impact?: 'high' | 'medium' | 'low';
}

const { title, status, impact = 'medium' } = Astro.props;

const impactBg = impact === 'high' ? '#d6e3ff' : '#e8e5ff';
const impactColor = impact === 'high' ? '#124687' : '#434750';
const impactLabel = impact === 'high' ? 'Impacto Alto' : impact === 'medium' ? 'Impacto Medio' : 'Impacto Bajo';
---

<div style={`display:flex;align-items:center;gap:16px;padding:12px 16px;border-radius:10px;transition:background 0.15s;${status === 'in_progress' ? 'background:#f5f2ff;box-shadow:0 0 0 1px rgba(0,52,109,0.08);' : ''}`}>
  {status === 'done' && (
    <span class="material-symbols-outlined filled-icon" style="color:#1d9e75;font-size:20px;flex-shrink:0;">check_circle</span>
  )}
  {status === 'in_progress' && (
    <div style="width:20px;height:20px;border-radius:50%;border:2px solid #ba7517;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <div style="width:8px;height:8px;border-radius:50%;background:#ba7517;"></div>
    </div>
  )}
  {status === 'pending' && (
    <span class="material-symbols-outlined" style="color:#c3c6d2;font-size:20px;flex-shrink:0;">radio_button_unchecked</span>
  )}

  <span style={`flex:1;font-size:14px;font-weight:${status === 'in_progress' ? '700' : '500'};color:${status === 'done' ? '#434750' : '#1a1a2e'};${status === 'done' ? 'text-decoration:line-through;opacity:0.5;' : ''}`}>
    {title}
  </span>

  <span style={`padding:2px 8px;border-radius:999px;background:${impactBg};color:${impactColor};font-size:10px;font-weight:700;white-space:nowrap;`}>
    {impactLabel}
  </span>
</div>
