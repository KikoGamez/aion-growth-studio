---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-24 md:py-32 bg-aion-dark relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-aion-cyan/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-aion-emerald/5 rounded-full blur-3xl"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto px-6 md:px-8">
    <div class="max-w-4xl mx-auto text-center fade-in">

      <!-- Quote icon -->
      <div class="flex justify-center mb-8">
        <div class="w-16 h-16 rounded-2xl glass flex items-center justify-center">
          <svg class="w-8 h-8 text-aion-cyan" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
        </div>
      </div>

      <blockquote class="headline-lg text-white mb-12 leading-relaxed">
        &ldquo;{t('testimonial.quote')}&rdquo;
      </blockquote>

      <div class="flex flex-col items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-aion-cyan to-aion-emerald flex items-center justify-center text-aion-dark font-display font-bold text-xl">
          AM
        </div>
        <div class="text-center">
          <p class="font-semibold text-white text-lg">{t('testimonial.name')}</p>
          <p class="text-white/50">{t('testimonial.role')}</p>
        </div>
      </div>

    </div>
  </div>
</section>
